//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
DEVICE nch_hvish_nbl_mac ngthvish_reg hvndfd(D) poly(G) hvndfd(S) HVPW(B) NBL(NBL_ISO) psub_under_nbl(SUB) <nthin_hv27> (S D) netlist model nch_hvish_nbl_mac [
   property W,L,AS,AD,PS,PD,hvpwdio_hv_area,hvpwdio_hv_pj,nbldio_hv_area,nbldio_hv_pj
   W = (perimeter_coincide(ngthvish_reg,hvndfd) + perimeter_inside(ngthvish_reg,hvndfd)) / 2
   L = area(ngthvish_reg) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD
     PD = perimeter(D) * W /PI_D_OD
     PS = PD } 
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS
     PS = perimeter(S) * W /PI_S_OD
     PD = PS } 
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD
     PS = perimeter(S) * W /PI_S_OD
     PD = perimeter(D) * W /PI_D_OD }
   hvpwdio_hv_area=0
   hvpwdio_hv_pj=0
   nbldio_hv_area=0
   nbldio_hv_pj=0

]
#ELSE

#IFDEF extract_as_ad
DEVICE nch_hvish_nbl_mac ngthvish_reg hvndfd(D) poly(G) hvndfd(S) HVPW(B) NBL(NBL_ISO) psub_under_nbl(SUB) <nthin_hv27> (S D) netlist model nch_hvish_nbl_mac [
