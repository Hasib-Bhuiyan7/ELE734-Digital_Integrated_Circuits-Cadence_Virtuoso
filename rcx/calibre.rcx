#IFDEF RC_DECK
DEVICE nch_hvi_mac ngthvi_mac hvndfd(D) poly(G) hvndfs(BS) psub_under_dnw(SUB) <HVPW> <mdiff> <nthin> [
	property W,L,AS,PS,AD,PD,DNW_AREA,DNW_PJ
	W=(perimeter_coincide(ngthvi_mac,hvndfs)+perimeter_coincide(ngthvi_mac,hvndfd))/2
	L=area(ngthvi_mac)/W
	PI_S_OD=perimeter_inside(BS,nthin)
	IF(PI_S_OD > 0) {
		AS=area(BS)*W/PI_S_OD
		PS=perimeter(BS)*W/PI_S_OD
	}ELSE{
		AS=0
		PS=0
	}
	PI_D_OD=perimeter_inside(HVPW,mdiff)
	IF(PI_D_OD > 0) {
		AD=area(HVPW)*W/PI_D_OD
		PD=perimeter(HVPW)*W/PI_D_OD
	}ELSE{
		AD=0
		PD=0
	}
	DNW_area=0
	DNW_pj=0
]
#ELSE
#IFDEF extract_as_ad
DEVICE nch_hvi_mac ngthvi_mac hvndfd(D) poly(G) hvndfs(BS) psub_under_dnw(SUB) <HVPW> <mdiff> <nthin> [
	property W,L,AS,AD
	W=(perimeter_coincide(ngthvi_mac,hvndfs)+perimeter_coincide(ngthvi_mac,hvndfd))/2
	L=area(ngthvi_mac)/W
	PI_S_OD=perimeter_inside(BS,nthin)
	IF(PI_S_OD > 0) {
		AS=area(BS)*W/PI_S_OD
	}ELSE{
		AS=0
	}
	PI_D_OD=perimeter_inside(HVPW,mdiff)
	IF(PI_D_OD > 0) {
		AD=area(HVPW)*W/PI_D_OD
	}ELSE{
		AD=0
	}
]
#ELSE
DEVICE nch_hvi_mac ngthvi_mac hvndfd(D) poly(G) hvndfs(BS) psub_under_dnw(SUB) [
	property W,L
	W=(perimeter_coincide(ngthvi_mac,hvndfs)+perimeter_coincide(ngthvi_mac,hvndfd))/2
	L=area(ngthvi_mac)/W
]
TRACE PROPERTY nch_hvi_mac W W MOS_Werr
TRACE PROPERTY nch_hvi_mac L L MOS_Lerr
#ENDIF
#ENDIF
