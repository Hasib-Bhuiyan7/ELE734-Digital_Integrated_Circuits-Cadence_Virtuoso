   property W,L,AS,AD
   W = (perimeter_coincide(pgthva_mac,hvpdfs) + perimeter_coincide(pgthva_mac,hvpdfd)) / 2
   L = area(pgthva_mac) / W
   PI_S_OD = perimeter_inside(S,pthin_hv27)
   PI_D_OD = perimeter_inside(D,pthin_hv27)
   IF(PI_S_OD > 0) {
     AS = area(S) * W /PI_S_OD
   } ELSE { AS=0 }
   IF(PI_D_OD > 0) {
     AD = (area(D) * W /PI_D_OD) //Myron example for divided by ratio of length
   } ELSE { AD=0 }
]

#ELSE
DEVICE pch_hva_pdd_mac pgthva_mac hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) [
   property W,L
   W = (perimeter_coincide(pgthva_mac, hvpdfs) + perimeter_coincide(pgthva_mac, hvpdfd)) / 2
   L = area(pgthva_mac) / W
]
#ENDIF

