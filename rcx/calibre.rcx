#IFDEF RC_DECK
DEVICE pch_hva_mac pgthvan_mac hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) psub_under_dnw(SUB) <pthin_hv> [
	property W,L,AS,PS,AD,PD,DNW_AREA,DNW_PJ
	W=(perimeter_coincide(pgthvan_mac,hvpdfs)+perimeter_coincide(pgthvan_mac,hvpdfd))/2
	L=area(pgthvan_mac)/W
	PI_S_OD=perimeter_inside(S,pthin_hv)
	PI_D_OD=perimeter_inside(D,pthin_hv)
	IF(PI_S_OD > 0) {
		AS=area(S)*W/PI_S_OD
		PS=perimeter(S)*W/PI_S_OD
	}ELSE{
		AS=0
		PS=0
	}
	AD=area(D)*W/PI_D_OD
	PD=perimeter(D)*W/PI_D_OD
	DNW_area=0
	DNW_pj=0
]
#ELSE
#IFDEF extract_as_ad
DEVICE pch_hva_mac pgthvan_mac hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) psub_under_dnw(SUB) <pthin_hv> [
	property W,L,AS,AD
	W=(perimeter_coincide(pgthvan_mac,hvpdfs)+perimeter_coincide(pgthvan_mac,hvpdfd))/2
	L=area(pgthvan_mac)/W
	PI_S_OD=perimeter_inside(S,pthin_hv)
	PI_D_OD=perimeter_inside(D,pthin_hv)
	IF(PI_S_OD > 0) {
		AS=area(S)*W/PI_S_OD
	}ELSE{
		AS=0
	}
	AD=area(D)*W/PI_D_OD
]
#ELSE
DEVICE pch_hva_mac pgthvan_mac hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) psub_under_dnw(SUB) [
	property W,L
	W=(perimeter_coincide(pgthvan_mac,hvpdfs)+perimeter_coincide(pgthvan_mac,hvpdfd))/2
	L=area(pgthvan_mac)/W
]
TRACE PROPERTY pch_hva_mac W W MOS_Werr
TRACE PROPERTY pch_hva_mac L L MOS_Lerr
#ENDIF
#ENDIF
