   W = (perimeter_coincide(ngthvish_reg,hvndfd) + perimeter_inside(ngthvish_reg,hvndfd)) / 2
   L = area(ngthvish_reg) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD }
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS }
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD }
]

#ELSE
DEVICE nch_hvish_nbl_mac ngthvish_reg hvndfd(D) poly(G) hvndfd(S) HVPW(B) NBL(NBL_ISO) psub_under_nbl(SUB) (S D) [
   property W,L
   W = (perimeter_coincide(ngthvish_reg, hvndfd) + perimeter_inside(ngthvish_reg, hvndfd)) / 2
   L = area(ngthvish_reg) / W
]
