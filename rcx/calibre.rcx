#IFDEF RC_DECK
DEVICE pch_hva_pdd_mac pgthva_mac hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) <pthin_hv27> netlist model pch_hva_pdd_mac [
   property W,L,AS,AD,PS,PD
   W = (perimeter_coincide(pgthva_mac,hvpdfs) + perimeter_coincide(pgthva_mac,hvpdfd)) / 2
   L = area(pgthva_mac) / W
   PI_S_OD = perimeter_inside(S,pthin_hv27)
   PI_D_OD = perimeter_inside(D,pthin_hv27)
   IF(PI_S_OD > 0) {
     AS = area(S) * W / PI_S_OD
     PS = perimeter(S) * W /PI_S_OD
   } ELSE { AS=0 PS=0 }
   IF(PI_D_OD > 0) {
     AD = area(D) * W /PI_D_OD
     PD = perimeter(D) * W /PI_D_OD
   } ELSE { AD=0 PD=0 }
]
#ELSE

#IFDEF extract_as_ad
