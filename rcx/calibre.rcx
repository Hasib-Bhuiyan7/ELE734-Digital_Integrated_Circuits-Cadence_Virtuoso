//   D[PWHVNW_DIO_60]      PW/HVNW HV diode       (DIODMY*OD*PIMP*HVNW*HV60DMY*SH_P) 
//   D[NBLPEPI_DIO_60]     HVNW_NBL/P-epi diode   (DIODMY*OD*NIMP*HVNW*NBL*HV60DMY) 
//   D[ZD_DIO_60]          Zener diode            (DIODMY*NIMP*OD*HVPB*HVNW*SH_P*DPW*NBL*SH_N*HVNW*PIMP*POLY1*HV60DMY) 
//   sbd_dio_60            Schottky diode         (DIODMY*HVNW*SH_P*NBL*PIMP*RPO*HV60DMY) 
// 
//   D[npdd_dio]           N+/PDD diode           (DIODMY*OD*NIMP*PDD_BCD*HVNW*RPO) 
//   D[ldpwhvnw_dio]       LDPW/HVNW diode        (DIODMY*LDPW*HVNW) 
//   D[hvnwpsub_dio]       HVNW/psub diode        (DIODMY*OD*NIMP-LDPW*HVNW) 
//    
//   phvnw_dio_hvpw_3t    	3T P+/HVNW diode		(DIO3TDMY*OD*PIMP*HVNW*HVOX) 
//   hvpwdnwhvnw_dio_hvpw_3t	3T HVPW/HVNW/DNW diode		(DIO3TDMY*HVOX*HVNW*DNW*OD*PIMP) 
//   D[hvnwdnwpsubhvpw_dio]	HVNW+DNW/PSUB(HVPW) diode	(DIODMY*HVNW*DNW*HVOX*NIMP*OD) 
//   lvpwdnwhvnw_dio_hvpw_3t      3T LVPW/HVNW/DNW diode    	(HVOX*DIO3TDMY*PSUB*HVNW*DNW) 
// 
//   D[pdio_hv]            P+/HVNW diode          (DIODMY*OD*PIMP*HVNW*HVOX) 
//   D[ndio_hv]            N+/HVPW diode          (DIODMY*OD*NIMP*HVOX) 
//   D[hvnwdio_hv]         HVNW/HVPW diode        (DIODMY*OD*NIMP*HVNW*HVOX-DNW-NBL) 
//   D[hvpwdio_hv]         HVPW/HVNW/NBL diode    (DIODMY*HVOX*HVNW*NBL*OD*PIMP) 
//   D[lvpwdio_hv]         LVPW/HVNW/NBL diode    (DIODMY*PSUB*HVNW*NBL*OD2) 
//   D[nbldio_hv]          HVNW+NBL/HVPW diode    (DIODMY*HVNW*NBL*HVOX*NIMP*OD) 
// 
//   D[nddhvpw_dio]        NDD/HVPW DIODE         (DIODMY*OD*NDD*NIMP*HVOX) 
//   D[pddhvnw_dio]        PDD/HVNW DIODE         (DIODMY*OD*PDDi*PIMP*HVNW) 
// 
//   Q[NHVPWNBL10]      10*10  N+/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*HVNW) 
//   Q[NHVPWNBL5]       5*5    N+/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*HVNW) 
//   Q[NHVPWNBL2]       2*2    N+/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*HVNW) 
//   Q[PWHVNWDPW10]     10*10  PW/HVNW/DPW  BJT   (BJTDMY*OD*PIMP*HVNW*SH_P*DPW*HV40DMY) 
//   Q[PWHVNWDPW5]      5*5    PW/HVNW/DPW  BJT   (BJTDMY*OD*PIMP*HVNW*SH_P*DPW*HV40DMY) 
//   Q[PWHVNWDPW2]      2*2    PW/HVNW/DPW  BJT   (BJTDMY*OD*PIMP*HVNW*SH_P*DPW*HV40DMY) 
//   Q[NWHVPWNBL10]     10*10  NW/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*SH_N*SH_P*NBL*HV40DMY) 
//   Q[NWHVPWNBL5]      5*5    NW/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*SH_N*SH_P*NBL*HV40DMY) 
//   Q[NWHVPWNBL2]      2*2    NW/HVPW/NBL  BJT   (BJTDMY*OD*NIMP*SH_N**SH_P*NBL*HV40DMY) 
// 
//   Q[NPWNBL10]        10*10  N+/LVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*NOPW*SH_P) 
//   Q[NPWNBL5]         5*5    N+/LVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*NOPW*SH_P) 
//   Q[NPWNBL2]         2*2    N+/LVPW/NBL  BJT   (BJTDMY*OD*NIMP*NBL*HV40DMY*NOPW*SH_P) 
// 
//   NHVPWDNW10_4t	NPN(HV BJT)(N+/HVPW/DNW)10x10   (HVNW*HVOX*BJTDMY_4t*OD*NIMP*DNW) 
//   NHVPWDNW5_4t		NPN(HV BJT)(N+/HVPW/DNW)5x5     (HVNW*HVOX*BJTDMY_4t*OD*NIMP*DNW) 
// 
//   Q[HVNWDPWNBL10_60] HVNW/DPW/NBL+HVNW BJT     (BJTDMY*OD*NIMP*NBL*HV60DMY*DPW*HVNW*SH_N) 
//   Q[HVNWDPWNBL5_60]  HVNW/DPW/NBL+HVNW BJT     (BJTDMY*OD*NIMP*NBL*HV60DMY*DPW*HVNW*SH_N) 
//   Q[HVNWDPWNBL2_60]  HVNW/DPW/NBL+HVNW BJT     (BJTDMY*OD*NIMP*NBL*HV60DMY*DPW*HVNW*SH_N) 
//   Q[NHVPWNBL10_60]   N+/HVPW/NBL+HVNW  BJT     (BJTDMY*OD*NIMP*NBL*HV60DMY*SH_N*HVNW) 
//   Q[NHVPWNBL5_60]    N+/HVPW/NBL+HVNW  BJT     (BJTDMY*OD*NIMP*NBL*HV60DMY*SH_N*HVNW) 
// 
//   Q[NPWNBL10_60]     N+/PW/NBL+HVNW    BJT     (BJTDMY*OD*NIMP*SH_P*NOPW*NBL*HV60DMY) 
//   Q[NPWNBL5_60]      N+/PW/NBL+HVNW    BJT     (BJTDMY*OD*NIMP*SH_P*NOPW*NBL*HV60DMY) 
//   Q[NPWNBL2_60]      N+/PW/NBL+HVNW    BJT     (BJTDMY*OD*NIMP*SH_P*NOPW*NBL*HV60DMY) 
//   Q[NWHVPWNBL10_60]  NW/HVPW/NBL+HVNW BJT      (BJTDMY*OD*NIMP*NBL*HV60DMY*SH_N) 
//   Q[NWHVPWNBL5_60]   NW/HVPW/NBL+HVNW BJT      (BJTDMY*OD*NIMP*NBL*HV60DMY*SH_N) 
//   Q[NWHVPWNBL2_60]   NW/HVPW/NBL+HVNW BJT      (BJTDMY*OD*NIMP*NBL*HV60DMY*SH_N) 
//   Q[PHVNWDPW10_60]   P+/HVNW/DPW BJT           (BJTDMY*OD*PIMP*HVNW**DPW*HV60DMY) 
//   Q[PHVNWDPW5_60]    P+/HVNW/DPW BJT           (BJTDMY*OD*PIMP*HVNW**DPW*HV60DMY) 
//   Q[PHVNWDPW2_60]    P+/HVNW/DPW BJT           (BJTDMY*OD*PIMP*HVNW**DPW*HV60DMY) 
// 
//   Q[nldpwhvnw10]     N+/LDPW/HVNW BJT          (BJTDMY*OD*NIMP*LDPW*HVNW*) 
//   Q[nldpwhvnw5]      N+/LDPW/HVNW BJT          (BJTDMY*OD*NIMP*LDPW*HVNW*) 
//   Q[nldpwhvnw2]      N+/LDPW/HVNW BJT          (BJTDMY*OD*NIMP*LDPW*HVNW*) 
//   Q[ldpwhvnwpsub10]  LDPW/HVNW/psub BJT        (BJTDMY*OD*PIMP*LDPW*HVNW*) 
//   Q[ldpwhvnwpsub5]   LDPW/HVNW/psub BJT        (BJTDMY*OD*PIMP*LDPW*HVNW*) 
//   Q[ldpwhvnwpsub2]   LDPW/HVNW/psub BJT        (BJTDMY*OD*PIMP*LDPW*HVNW*) 
//    
//   Q[phvnwpsub2]      P+/HVNW/PSUB 2*2          (BJTDMY*OD*PIMP*HVNW*HVOX-PDD) 
//   Q[phvnwpsub5]      P+/HVNW/PSUB 5*5          (BJTDMY*OD*PIMP*HVNW*HVOX-PDD) 
//   Q[phvnwpsub10]     P+/HVNW/PSUB 10*10        (BJTDMY*OD*PIMP*HVNW*HVOX-PDD) 
//   Q[pddhvnwpsub2]    PDD/HVNW/PSUB 2*2         (BJTDMY*OD*PDD*PIMP*HVNW*HVOX) 
//   Q[pddhvnwpsub5]    PDD/HVNW/PSUB 5*5         (BJTDMY*OD*PDD*PIMP*HVNW*HVOX) 
//   Q[pddhvnwpsub10]   PDD/HVNW/PSUB 10*10       (BJTDMY*OD*PDD*PIMP*HVNW*HVOX) 
//    
//   rhvnwhvpw          HVNW_HVPW Resistor        (RWDMYX*HVNW*HVOX) 
//   rnddhvpw           NDD_HVPW  Resistor        (RPDMYX*NDD*OD*HVOX*NIMP*RPO) 
//   rpddhvnw           PDD_HVNW  Resistor        (RPDMYX*PDD*OD*HVNW*HVOX*PIMP*RPO) 
// 
//   rhvnw              HVNW_HVPW Resistor        (RWDMYX*HVNW*HV40DMY) 
//   rhvpw              HVPW_HVNW+NBL Resistor    (RWDMYX*HVNW*NBL*HV40DMY) 
//   rhvnw_60           HVNW_HVPW Resistor        (RWDMYX*HVNW*HV60DMY) 
//   rhvpw_60           HVPW_HVNW+NBL Resistor    (RWDMYX*NBL*HV60DMY*HVNW) 
// 
//   rpbody             PBODY Resistor            (RPDMYX*HVNW*HVOX*OD*RPO*HVPB*PIMP) 
//   rldpwod            LDPW Resistor under OD    (RWDMYX*HVNW*HVOX*OD*RPO*LDPW) 
//   rldpwsti           LDPW Resistor under STI   (RWDMYX*HVNW*HVOX-OD-RPO*LDPW) 
//    
//   rhim	              SiCr resistor		(MSi*M0) 
//   --------------------------------------------------------------------- 
//   Parasitic DEVICE 
//   --------------------------------------------------------------------- 
//    
//   D[PPDPWNBL_DIO]        HV parasitic DPW/NBL diode          (DPW*NBL*HV40DMY-DIODMY) 
//   D[PPNBLPEPI_DIO]       HV parasitic NBL/PEPI diode         (NBL*PSUB*HV40DMY-DIODMY) 
//   D[PWPEPINBL_DIO]       LV isolaiton CORE PW/NBL diode      (NBL*HVNW-OD2-HV40DMY-DIODMY) 
//   D[PWPEPINBL_DIO_5]     LV isolation IO PW/NBL diode        (NBL*HVNW*OD2-HV40DMY-DIODMY) 
//   D[NBLPEPI_ISO_DIO]     LV isolation NBL/PEPI diode         (NBL*PSUB*HVNW-HV40DMY-DIODMY) 
// 
//   D[PPDPWNBL_DIO_60]     HV parasitic DPW/NBL diode          (DPW*NBL*HV60DMY-DIODMY) 
//   D[PPNBLPEPI_DIO_60]    HV parasitic NBL/PEPI diode         (NBL*PSUB*HV60DMY-DIODMY) 
//   D[PWPEPINBL_DIO_60]    LV isolaiton CORE PW/NBL diode      (NBL*HVNW-OD2-HV60DMY-DIODMY) 
//   D[PWPEPINBL_DIO_5_60]  LV isolation IO PW/NBL diode        (NBL*HVNW*OD2-HV60DMY-DIODMY) 
//   D[NBLPEPI_ISO_DIO_60]  LV isolation NBL/PEPI diode         (NBL*PSUB*HVNW-HV60DMY-DIODMY) 
// 
//   D[ppldpwhvnw_dio] Parasitical diode for isolation LDPW/HVNW  (LDPW*HVNW*NIMP-DIODMY**OD*POLY1i*NWELL) 
//   D[pphvnwpsub_dio] Parasitical diode for isolation HVNW/psub  (HVNW-DIODMY*OD*POLY1i*NWELL) 
//    
//   D[pphvpwdio_hv_iso]    HV parasitic HVPW/HVNW/NBL diode    (HVOX*HVNW*NBL*OD*PIMP*NDD_BCD-DIODMY*NGATE*RPO) 
//   D[ppnbldio_hv_iso]     HV parasitic HVNW+NBL/HVPW diode    (HVNW*NBL*HVOX*NIMP*OD*NDD_BCD-DIODMY*NGATE*RPO) 
// 
//   D[pphvnwdnwpsubhvpw_dio_iso_ac]	HV parasitic HVNW+DNW/PSUB(HVPW) DIODE for 3T DIODE (HVOX*HVNW*DNW-DIODMY*DIO3TDMY) 
//   D[pphvnwdnwpsubhvpw_dio_iso]		HV parasitic HVNW+DNW/PSUB(HVPW) DIODE	(HVOX*HVNW*DNW-DIODMY-DIO3TDMY) 
//   D[pphvnwpsubhvpw_dio_iso_ac]		HV parasitic HVNW/HVPW DIODE		(HVOX*HVNW-DIODMY*DIO3TDMY-NBL-DNW) 
// 
//   D[dnwpsub]     DNW/PSUB diode	     	(DNW*PSUB*NWELL)  
//   D[pwdnw]       PSUB(R-WELL)/DNW diode	(DNW*PSUB-OD2-NWELL)  
// 
//   D[pnwdio]	  CORE diode NW/PW          (NWELL-OD2-DIODMY)   
// 
//   D[pnwdio_3]	  I/O  diode NW/PW          (NWELL*OD2-DIODMY)   
// 
//   D[pnwdio_ull]  CORE diode ULLNW/PW       (ULLNW*OD3-OD2-DIODMY)   
//   D[pnwdio_ell]  CORE diode ULLNW/PW       (ULLNW*OD3-OD2-DIODMY*ELLDMY)   
//    
//   ----------------------------------------------------------------------------------------  
//   * POLY1 = POLY1i 
//   * NGATE = OD * POLY1i * NIMP - NWELL - MTDUM   
//   * PGATE = OD * POLY1i * PIMP * NWELL - MTDUM  
//   * HVPGATE = OD * POLY1i * PIMP * HVNWi 
//   * PSUB = BULK  
//   * VARDMY = VARDMYX -VARG3 -VARG6 -JVARD  
//   * VARGT = OD * POLY1i * NIMP * NWELL * VARDMYX 
//   * RFNGATE = OD * POLY1i * NIMP - NWELL  
//   * RFPGATE = OD * POLY1i * PIMP * NWELL  
//   * RFDUMMY = RFDUMMYX + RFDUMMY1  
//   * PDDi  = PDD + PDD_BCD 
//   * HVNW  = HVNWi 
//   * HVPB  = HVPBi 
//   * METAL1 = M1  
//   * RMDMY1 = RMDMY1i 
//   * METAL2 = M2  
//   * RMDMY2 = RMDMY2i 
//   * METAL3 = M3  
//   * RMDMY3 = RMDMY3i 
//   * METAL4 = M4  
//   * RMDMY4 = RMDMY4i 
//   * METAL5 = M5  
//   * RMDMY5 = RMDMY5i 
//   * METAL6 = M6  
//   * RMDMY6 = RMDMY6i 
// 
//////////////////////////////////////////////////////////////////////////////// 
// 
//////////////////////////////////////////////////////////////////////////////// 
//USER NOTES :   
//   
// 1) mnpg49 mppg49 are obtained in a DRC run, not in an LVS run.   
//   
// 2) For Calibre "EDTEXT" file, use .INCLUDE strings.txt.   
//        LAYOUT TEXT  "text string" [x] [y]  (layer num) (cell name)   
//   
// 3) Input layer 'OD' is defined as thin oxide (OD) area which would    
//    be drawn by one generic od mask or by seperated N+OD and P+OD.    
//    Remove layers in the 'OD' entries you don't want to use at    
//    layer definition block.   
//   
// 4) Default setting for property check is 0%. Users should check with   
//    IP/Designe providers for proper tolerance.   
//   
// 5) It's recommended to run Calibre LVS by hierarchical mode since false   
//    errors have been encountered by only flat mode option '-lvs'.   
//   
// 6) Default property resolution for ambiguity is set to 32. It could be   
//    necessary to increase this setting to resolve serious ambiguity.   
//    Uncomment statement 'LVS PROPERTY RESOLUTION MAXIMUM' in this deck   
//    to reset the capability of property resolution.   
//   
// 7) This deck default not to extracts MOS AS/AD property. To turn on the   
//    extraction of MOS AS/AD property, please uncomment the line   
//    "#DEFINE extract_as_ad". It would cause SEED PROMOTION, and pose   
//    much overhead on layout netlist extraction, erc checks, and lvs 
//	comparison. 
// 
// 8) For MOS capacitors, AS and AD values are calculated by combining the 
//    total amount of source and drain area for the device and splitting up 
//	the result evenly between AS and AD. PS and PD values are similarily  
//	calculated by evenly splitting up the total amount of source and drain 
//	perimeter. This is valid since simulation results for MOS capacitors 
//	should not depend on how AS/AD and PS/PD are split up between source 
//	and drain.  
//  
// 9) "VIRTUAL CONNECT COLON YES" : By default, VIRTUAL CONNECT COLON is set 
//    yes. Please set to NO as doing full-chip checking  
//  
// 10) So far, only 0.18um process 2T BB mimcap and rf mimcap w/i shield 
//     support stacking mimcap. If this LVS deck is 0.18um process and 
//	 w/i rf devices, it will support device under mimcap. And please 
//	 do not put metal resistor w/i RMDMY(69;0) under the mimcap.  
//  
// 11) The resistor value extracted from this deck was just for LVS check.  
//     The exact resistor value should base on spice simulation.  
// 
// 12) There is no difference with ACCURACY switch on/off and the R paramter 
//     is a simple resistance calculation for reference only. The simple R 
//	 equation here is "r=rsh*L/W". Please ALWAYS refer to the corresponding 
//	 model for real R equation and resistance from post-sim result. 
///////////////////////////////////////////////////////////////////////////////////////  
//                      Introduction to each switch  
//  
//   -------------------------	----------------------------------------------------------  
//   SWITCH NAME                  		DESCRIPTION                 
//   -------------------------	----------------------------------------------------------  
//   Accuracy        	            RESISTANCE VALUE VARIABLE SETTING   
//   
//   ZERO_NRS_NRD	                Set nrd=0 and nrs=0 when run RCX extraction flow.    
//  
//   NW_RING                      If turn on this switch, the soft-connect check for nwell   
//                                ring and psub(rwell) inside will not be checked.  
//  
//   WELL_TO_PG_CHECK             ERC_check for ntap connected to ground, default is turned on.  
//    
//   GATE_TO_PG_CHECK             ERC_check for gate connected to ground, default is turned off.  
//    
//   FLOATING_GATE_CHECK          Floating gate check, default is turned on.  
//   
//   FLOATING_WELL_CHECK          Floating well check, default is turned on.  
//    
//   DS_TO_PG_CHECK               ERC_check for MOS connected to both power and ground, default  
//                                turned on.  
// 
//   PATH_CHECK                   PATH_CHECK for net, default is turned off. 
// 
//   MACRO                        By default, macro models are not netlisted. Please turn on 
//                                this switch to enable "_mac" models. 
// 
//   extract_parasitic_diodes     By default, the parasitic diodes are not extracted in this  
//                                command file. Please turn on the this switch to apply the 
//				extraction of parasitic diodes.    
// 
//   compare_parasitic_diodes     By default, the parasitic diodes are not compared in this  
//                                command file. Please turn on the this switch to apply the 
//				comparison of parasitic diodes. 
// 
//////////////////////////////////////////////////////////////////////////////////////////  
//lvs_gen.pl version: 1.4
//calibre.pl version: 1.4

// LVS/RC switch option
// --------------------
#define RC_DECK    //uncomment this line when this deck would be used as a RC command file
//#define ZERO_NRS_NRD    //uncomment this line when this deck would set NRS=0 and NRD=0 
//#define FILTER_DGS_TIED_MOS // uncomment this line to filter MOS with D, G and S tied together (default filter MOS with all pins tied)
#define WELL_TO_PG_CHECK 
// Default is on. Turn on to highlight if nwell connects to ground or psub connects to power.
//#define GATE_TO_PG_CHECK 
// Default is off. Turn on to highlight if a mos gate directly connects to power or ground.
//#define PATH_CHECK 
// Default is off. Turn on to highlight if
//(1) nodes have a path to power but no path to ground
//(2) nodes have a path to ground but no path to power
//(3) nodes have no path to power or ground
//(4) nodes have no path to any label net
#define DS_TO_PG_CHECK 
// Default is on. Turn on to highlight if drain connects to power and source connects to ground.
#define FLOATING_GATE_CHECK 
// Default is on. Turn on to highlight if there are floating gates.
#define FLOATING_WELL_CHECK 
// Default is on. Turn on to highlight if well does not connect to power or ground. 
//The nwell of moscaps and nwell-resistor are excluded.

VARIABLE WPED 5.0
VARIABLE PRESCALE 1.0

//#define NW_RING	//uncomment this line to enable the NW ring to separate the node from BULK

// POWER and GROUND name string variable setting
VARIABLE POWER_NAME  "AVD33"  "AVD33B"  "AVD33G"  "AVD33R"  "AVD33WELL"  "AVDD"  "AVDDB"  "AVDDBG"  "AVDDG"  "AVDDR"  "AVDWELL"  "DVDD"  "TAVD33"  "TAVD33PST"  "TAVDD"  "TAVDDPST"  "TVDD"  "VD33"  "VD33WELL"  "VDD"  "VDD5V"  "VDDESD"  "VDDG"  "VDDM"  "VDDPST"  "VDDSA"  "VDWELL" 

VARIABLE GROUND_NAME  "AGND"  "AVS33"  "AVS33B"  "AVS33G"  "AVS33R"  "AVS33SUB"  "AVSS"  "AVSSB"  "AVSSBG"  "AVSSG"  "AVSSR"  "AVSSUB"  "DVSS"  "GND"  "TACVSS"  "TAVSS"  "TAVSSPST"  "TVSS"  "VS33"  "VS33SUB"  "VSS"  "VSSESD"  "VSSG"  "VSSM"  "VSSPST"  "VSSUB" 

//#########################################################################
//# ENVIRONMENT SETTING                              
//#########################################################################
// LVS option
// --------------------
//#define extract_as_ad
//

//  RC_BLOCKING SETTING
LAYOUT CELL LIST pcells "cfmom*" "cfmom_mx*" "cfmom_rf*" "crtmom*" "crtmom_rf*" "lcesd1_rf*" "lcesd2_rf*" "lowcpad_rf*" "mimcap_rf_2p0*" "mimcap_rf_2p0*" "mimcap_rf*" "mimcap_rf*" "mos_var*" "moscap_rf*" "mos_var33*" "moscap_rf33*" "moscap_rf33_nw*" "moscap_rf_nw*" "ndio_hia_rf*" "ndio_sbd_mac*" "rfnmos2v*" "rfnmos3v*" "rfnmos3v_6t*" "rfnmos2v_6t*" "pdio_hia_rf*" "rfpmos2v*" "rfpmos3v*" "rfpmos3v_5t*" "rfpmos3v_nw*" "rfpmos3v_nw_5t*" "rfpmos2v_5t*" "rfpmos2v_nw*" "rfpmos2v_nw_5t*" "rphripoly_rf*" "rplpoly_rf*" "rplpoly_rf*" "rphpoly_rf*" "sbd_rf*" "sbd_rf_nw*" "jvar*" "jvar*" 
LAYOUT PRESERVE CELL LIST pcells


LVS HEAP DIRECTORY "/tmp"

//RESISTANCE VALUE VARIABLE SETTING    
//#DEFINE ACCURACY

//By default, macro models are not netlisted. Please turn on this switch to enable "_mac" models.
//#DEFINE MACRO

//Default is turned off, turn on to use copper RDL 
//#DEFINE Cu_RDL         


//Below switch is controlled by LVS installation program, not recommend to change it by manual
//#DEFINE GP_PROCESS     

//Below switch is controlled by LVS installation program, not recommend to change it by manual
//#DEFINE PROCESS_WI_PURE5V_RES

//Below switch is controlled by LVS installation program, not recommend to change it by manual
//#DEFINE PROCESS_WO_MVTMOS_MACRO 

//uncomment the following line to apply the extraction of parasitic diodes
//#DEFINE extract_parasitic_diodes

//uncomment the following line to apply the comparison of parasitic diodes
//#DEFINE compare_parasitic_diodes

#IFDEF RC_DECK
 #DEFINE ACCURACY
#ENDIF

//#define STD_LIB
#IFDEF STD_LIB       // for tsmc 018 STD library, to estimate well proximity effect on STD cell.
	VARIABLE	NMOS_BOT_EXT 	0.86*1e-6
	VARIABLE	PMOS_TOP_EXT 	1.09*1e-6
	VARIABLE	MOS_LR_EXT 		100.0*1e-6
#ELSE
	VARIABLE	NMOS_BOT_EXT 	0
	VARIABLE	PMOS_TOP_EXT 	0
	VARIABLE	MOS_LR_EXT	 	0
#ENDIF

// LVS Error tolerance
	VARIABLE	MOS_Werr		0		//  MOS width
	VARIABLE	MOS_Lerr		0		//  MOS length
	VARIABLE	DIO_Aerr		0		//  Diode area
	VARIABLE	DIO_Werr		0		//  Diode width
	VARIABLE	DIO_Lerr		0		//  Diode length
	VARIABLE	BJT_Aerr		0		//  BJT area
	VARIABLE	RES_Werr		0		//  Resistor width
	VARIABLE	RES_Lerr		0		//  Resistor length
	VARIABLE	MIMCAP_Werr		0		//  MIM CAP width
	VARIABLE	MIMCAP_Lerr		0		//  MIM CAP length
	VARIABLE	MOSCAP_Werr		0		//  MOS CAP width
	VARIABLE	MOSCAP_Lerr		0		//  MOS CAP length
	VARIABLE	SPIRAL_Werr		0		//  Inductor width
	VARIABLE	SPIRAL_Serr		0		//  Inductor space
	VARIABLE	SPIRAL_Rerr		0		//  Inductor radius
	VARIABLE	SPIRAL_Gerr		0		//  Inductor gdis
	VARIABLE	MOM_Werr		0		//  MOM width
	VARIABLE	MOM_Lerr		0		//  MOM length
	VARIABLE	MOM_Serr		0		//  MOM space
	VARIABLE	RFMOS_Werr		0		//  RF MOS width
	VARIABLE	RFMOS_Lerr		0		//  RF MOS length
	VARIABLE	VAR_Werr		0		//  Varator width
	VARIABLE	VAR_Lerr		0		//  Varator length
// End tolerance setting

LAYOUT PRIMARY "ts_allcelllvs"
LAYOUT PATH "ts_allcelllvs.gds"
LAYOUT SYSTEM GDSII
//LAYOUT PATH "layout.net"
//LAYOUT SYSTEM SPICE

SOURCE PRIMARY "ts_allcelllvs"
SOURCE PATH "ts_allcelllvs.cdl"
SOURCE SYSTEM SPICE

DRC RESULTS DATABASE "calibre_drc.db" ASCII // ASCII or GDSII
DRC SUMMARY REPORT "calibre_drc.sum"

ERC RESULTS DATABASE "calibre_erc.db" ASCII
ERC SUMMARY REPORT "calibre_erc.sum"

LVS REPORT "lvs.rep"
LVS REPORT MAXIMUM 1000 // ALL

#IFDEF RC_DECK
  //MASK RESULTS DATABASE NONE //"mask.db"
#ELSE
  MASK RESULTS DATABASE NONE //"mask.db"
#ENDIF

#IFDEF RC_DECK
  //MASK SVDB DIRECTORY "svdb" QUERY
#ELSE
  MASK SVDB DIRECTORY "svdb" QUERY
#ENDIF
LVS ISOLATE SHORTS YES
LVS REPORT OPTION S

PRECISION 1000
RESOLUTION 1
UNIT LENGTH U

#IFDEF RC_DECK
  //UNIT CAPACITANCE F
#ELSE
  UNIT CAPACITANCE F
#ENDIF

TEXT DEPTH PRIMARY
PORT DEPTH PRIMARY

FLAG SKEW YES
FLAG OFFGRID YES

LVS SPICE PREFER PINS	       YES
LVS ABORT ON SUPPLY ERROR      NO
LVS ALL CAPACITOR PINS SWAPPABLE YES
LVS RECOGNIZE GATES            NONE
LVS IGNORE PORTS               NO
LVS CHECK PORT NAMES          YES
LVS REDUCE PARALLEL BIPOLAR    YES
LVS REDUCE PARALLEL MOS        YES
LVS REDUCE PARALLEL DIODES     YES
LVS REDUCE PARALLEL CAPACITORS YES
LVS REDUCE PARALLEL RESISTORS  YES
LVS REDUCE SERIES RESISTORS    YES      //Smashes series resistors
LVS REDUCE SERIES CAPACITORS   YES      //Smashes series capacitors
LVS REDUCE SPLIT GATES         NO       //Smashes MOS split-gates.
//LVS FILTER UNUSED OPTION B D E O
//Strongly recommand to comment FILTER_DGS_TIED_MOS switch
//AG is to filter MOS with all pins tied together, AB is to filter MOS with D,G,S tied together
#IFNDEF FILTER_DGS_TIED_MOS
LVS FILTER UNUSED OPTION AG RC RE RG
#ELSE
LVS FILTER UNUSED OPTION AB RC RE RG
#ENDIF
LVS PROPERTY RESOLUTION MAXIMUM 65536 // ALL

LAYOUT BASE LAYER OD POLY1i NIMP PIMP CONT
VIRTUAL CONNECT COLON YES

//HVMOS Gate-Shielding, only for Calibre RCX
hvnw_hvedge = hvndfd COINCIDENT EDGE ngthv1
hvpw_hvedge = hvpdfd COINCIDENT EDGE pgthv1
hvngate_lpe = INT poly hvnw_hvedge < 3 OPPOSITE REGION
hvpgate_lpe = INT poly hvpw_hvedge < 3 OPPOSITE REGION
hvgate_lpe = hvngate_lpe OR hvpgate_lpe  // for LPE purpose only
gate = hvgate_lpe OR gate_all     // for LPE purpose only


LVS POWER NAME POWER_NAME 
LVS GROUND NAME GROUND_NAME 
