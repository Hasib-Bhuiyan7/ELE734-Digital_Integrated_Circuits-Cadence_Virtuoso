//LVS REDUCE pch_hvsu_pdd_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

DEVICE pdio_hia_rf hia_pdio_rf_r tpdiff(PLUS) nxwell(MINUS) RFDMY_HIA_psub(BULK) <hia_pdio_rf> [
  property al,aw,fn
  fn = count(hia_pdio_rf)  
  A_DIO = area(hia_pdio_rf)/fn
  P_DIO = perimeter(hia_pdio_rf)/fn
  P_2_DIO = P_DIO * P_DIO
  AD4 = A_DIO * 16
  KKK = P_2_DIO-AD4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  al = (P_DIO+SQ)/4
  aw = (P_DIO-SQ)/4
]    

TRACE PROPERTY pdio_hia_rf aw aw DIO_Werr
TRACE PROPERTY pdio_hia_rf al al DIO_Lerr
TRACE PROPERTY pdio_hia_rf fn fn 0

#IFDEF RC_DECK
DEVICE phvnw_dio_hvpw_3t phvnw_dio_18_reg tpdiff(PLUS) HVNW(MINUS) psub_under_hvnw(SUB) [
	property AREA,PJ,HVNW_AREA,HVNW_PJ
	area=area(tpdiff)
	pj=perimeter(tpdiff)
	hvnw_area=0
	hvnw_pj=0
]
#ELSE
DEVICE phvnw_dio_hvpw_3t phvnw_dio_18_reg tpdiff(PLUS) HVNW(MINUS) psub_under_hvnw(SUB) [
	property area
	area=area(tpdiff)
]
TRACE PROPERTY phvnw_dio_hvpw_3t "area" "area" 0
#ENDIF
LVS DEVICE TYPE DIODE phvnw_dio_hvpw_3t [POS=PLUS NEG=MINUS]
LVS REDUCE phvnw_dio_hvpw_3t PARALLEL YES
[
	EFFECTIVE area
	area = sum( area )
]

