DEVICE pmos_rf pgate_4t_pthin d_tpdiff(D) poly_rf(G) s_tpdiff(S) nxwell(B) <pgate_rf4t> [
  property WR,LR,NR
  NR = count(pgate_rf4t)
  WR = ((perimeter_coincide(pgate_rf4t,d_tpdiff) + perimeter_coincide(pgate_rf4t,s_tpdiff))/2)/NR
  LR = (area(pgate_rf4t)/WR)/NR
