#IFDEF ACCURACY
  #IFDEF RC_DECK
    DEVICE R(nvmrpodrpo) prdop_nvm tpdiff tpdiff netlist model nvmrpodrpo netlist element "X" [
      property w,l,R
      w = perimeter_coincide(prdop_nvm,tpdiff)/2
      A = area(prdop_nvm)
      l = A/w
      R = 133*l/w
    ]
    //TRACE PROPERTY R(nvmrpodrpo) w w 0
    //TRACE PROPERTY R(nvmrpodrpo) l l 0
    TRACE PROPERTY R(nvmrpodrpo) R R 2
  #ELSE
    DEVICE R(nvmrpodrpo) prdop_nvm tpdiff tpdiff [
      property R
      w = perimeter_coincide(prdop_nvm,tpdiff)/2
      A = area(prdop_nvm)
      l = A/w
      R = 133*l/w
    ]
    TRACE PROPERTY R(nvmrpodrpo) R R 2
  #ENDIF
#ELSE
  DEVICE R(nvmrpodrpo) prdop_nvm tpdiff tpdiff [133]
    TRACE PROPERTY R(nvmrpodrpo) R R 0
#ENDIF

DEVICE nvmrpodrpo_m prdop_3t_nvm tpdiff(PLUS) tpdiff(MINUS) nxwell(B) (PLUS MINUS) [
	property l,w 
	w = perimeter_coincide(prdop_3t_nvm,tpdiff)/2
	l = area(prdop_3t_nvm)/w
]

TRACE PROPERTY nvmrpodrpo_m w w  RES_Werr
TRACE PROPERTY nvmrpodrpo_m l l  RES_Lerr

LVS REDUCE nvmrpodrpo_m PARALLEL YES 
[  TOLERANCE l 0  
   EFFECTIVE w,l
   l = SUM(l)/COUNT()
   w = SUM(w)

]
LVS REDUCE nvmrpodrpo_m SERIES PLUS MINUS YES
[  TOLERANCE w 0
   EFFECTIVE w,l
   w = SUM(w)/COUNT()
   l = SUM(l)
]

pa14g12_reg1 = pa14g12_reg NOT hvpdfd 
pa14g12_reg_w = pa14g12_reg1 COINCIDENT EDGE hvpdfd
hvpdfd_pa14g12_reg = DFM PROPERTY hvpdfd pa14g12_reg pa14g12_reg_w OVERLAP ABUT ALSO MULTI [ NG = COUNT(pa14g12_reg)] [NW = LENGTH(pa14g12_reg_w)]
#IFDEF RC_DECK
DEVICE LDDP(pa14_g12) pa14g12_reg hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) <pthin> <hvpdfd_pa14g12_reg> netlist model pa14_g12 netlist element "M" [
   property W,L,AS,AD,PS,PD
   W = perimeter_coincide(pa14g12_reg,hvpdfs)
   L = area(pa14g12_reg) / W
   AW = DFM_NUM_VAL (hvpdfd_pa14g12_reg,"NW") * UNIT_LENGTH() 
   PI_S_OD = perimeter_inside(S,pthin)
   IF(PI_S_OD > 0) {
    AS = area(S) * W /PI_S_OD
    PS = perimeter(S) * W /PI_S_OD
   } ELSE { AS=0 PS=0 }
   PI_D_OD = perimeter_inside(D,pthin)
   IF(PI_D_OD > 0) {
   AD = (area(hvpdfd_pa14g12_reg) * W/AW) //Myron example for divided by ratio of length
   PD = (perimeter(hvpdfd_pa14g12_reg) * W/AW) //Myron example for divided by ratio of length
   } ELSE { AD=0 PD=0 }
]
#ELSE

#IFDEF extract_as_ad
DEVICE LDDP(pa14_g12) pa14g12_reg hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) <pthin> <hvpdfd_pa14g12_reg> netlist model pa14_g12 [
  property W,L,AS,AD
  W = perimeter_coincide(pa14g12_reg,hvpdfs)
  L = area(pa14g12_reg) / W
  AW = DFM_NUM_VAL (hvpdfd_pa14g12_reg,"NW") * UNIT_LENGTH() 
  PI_S_OD = perimeter_inside(S,pthin)
  IF(PI_S_OD > 0) {
   AS = area(S) * W /PI_S_OD
  } ELSE { AS=0 }
  PI_D_OD = perimeter_inside(D,pthin)
  IF(PI_D_OD > 0) {
  AD = (area(hvpdfd_pa14g12_reg) * W/AW) //Myron example for divided by ratio of length
  } ELSE { AD=0 }
]
#ELSE

DEVICE LDDP(pa14_g12) pa14g12_reg hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) [
   property W,L
   W = perimeter_coincide(pa14g12_reg,hvpdfs)
   L = area(pa14g12_reg) / W
]
#ENDIF

TRACE PROPERTY LDDP(pa14_g12) L L MOS_Lerr
TRACE PROPERTY LDDP(pa14_g12) W W MOS_Werr
#ENDIF

