DEVICE rhim rhim_reg tfr(PLUS) tfr(MINUS) (PLUS MINUS) <M0> [
	property l,w
	w = perimeter_inside(M0,rhim_reg)/2
	l = area(rhim_reg)/w
	]
   TRACE PROPERTY rhim l l 0
   TRACE PROPERTY rhim w w 0

LVS REDUCE rhim PARALLEL YES
[  TOLERANCE l 0
   EFFECTIVE w,l
   l = SUM(l)/COUNT()
   w = SUM(w)
]

LVS REDUCE rhim SERIES PLUS MINUS YES
[ TOLERANCE w 0
  EFFECTIVE w,l
  w = SUM(w)/COUNT()
  l = SUM(l)
]

