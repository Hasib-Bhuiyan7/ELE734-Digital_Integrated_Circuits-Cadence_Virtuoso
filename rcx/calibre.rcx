LVS DEVICE TYPE NMOS nch_hvish_nbl_mac
//LVS REDUCE nch_hvish_nbl_mac PARALLEL YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE nch_hvish_nbl_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
DEVICE nch_hvish_ndd_mac ngthvis hvndfd(D) poly(G) hvndfd(S) HVPW(B) <nthin_hv27> (S D) netlist model nch_hvish_ndd_mac [
   property W,L,AS,AD,PS,PD
   W = (perimeter_coincide(ngthvis,hvndfd) + perimeter_inside(ngthvis,hvndfd)) / 2
   L = area(ngthvis) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD
     PD = perimeter(D) * W /PI_D_OD
     PS = PD } 
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS
     PS = perimeter(S) * W /PI_S_OD
     PD = PS } 
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD
     PS = perimeter(S) * W /PI_S_OD
     PD = perimeter(D) * W /PI_D_OD }  
]
#ELSE

#IFDEF extract_as_ad
DEVICE nch_hvish_ndd_mac ngthvis hvndfd(D) poly(G) hvndfd(S) HVPW(B) <nthin_hv27> (S D) netlist model nch_hvish_ndd_mac [
   property W,L,AS,AD
   W = (perimeter_coincide(ngthvis,hvndfd) + perimeter_inside(ngthvis,hvndfd)) / 2
   L = area(ngthvis) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD }
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS }
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD }
]

#ELSE
