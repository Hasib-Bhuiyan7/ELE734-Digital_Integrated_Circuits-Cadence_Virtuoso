//                             DEVICE FORMULA 
//   ----- ----------------------------- ---------------------------------- 
//   NAME  DESCRIPTION                   DEVICE LAYER OPERATION 
//   ----- ----------------------------- ---------------------------------- 
//   GENERIC DEVICE 
//   --------------------------------------------------------------------- 
//   M[N]           CORE Nominal VT NMOS          ((NGATE-OD2-NTN)-DNW)   
//   M[N1]          CORE Nominal VT NMOS/DNW      ((NGATE-OD2-NTN)*DNW)   
//   M[NA]          CORE medium  VT NMOS          ((NGATE-OD2-NTN)-DNW*VTMN)  
//   M[NL]          CORE native device            ((NGATE-OD2)*NTN)   
//   M[P]           CORE Nominal VT PMOS          (PGATE-OD2)  
//   M[PA]          CORE medium  VT PMOS          (PGATE-OD2*VTMP)  
//    
//   M[ND]          I/O  Nominal VT NMOS          ((NGATE*OD2-NTN)-DNW-VTMN)   
//   M[N2]          I/O  Nominal VT NMOS/DNW      ((NGATE*OD2-NTN)*DNW-VTMN)   
//   M[nch_ana33]     3.3V low noise NMOS         ((NGATE*OD2-NTN)*ANALOGDMYi-DNW)   
//   M[nch_ana33_dnw] 3.3V low noise NMOS         ((NGATE*OD2-NTN)*ANALOGDMYi*DNW)   
// 
//   M[NB]          I/O  medium  VT NMOS          ((NGATE*OD2-NTN)-DNW*VTMN)  
//   M[NN]          I/O  native device            ((NGATE*OD2)*NTN)   
// 
//   M[PD]          I/O  Nominal VT PMOS          (PGATE*OD2)  
//   M[pch_ana33]         3.3V low noise PMOS     (PGATE*OD2*ANALOGDMYi)  
// 
//    
//   M[UN]          ULL NMOS                      (OD*NIMP*POLY1-NTN-DNW*OD3) 
//   M[UP]          ULL PMOS                      (OD*PIMP*POLY1*OD3*ULLNW) 
//   M[nch_ell]     Extreme low leak NMOS         ((NGATE-OD2-NTN)-DNW*OD3*ELLDMY) 
//   M[pch_ell]     Extreme low leak PMOS         ((OD*POLY1*PIMP-OD2-NTN)-DNW*OD3*ULLNW*ELLDMY) 
//    
//   M[HN]          HV NMOS		                (OD*NIMP*POLY1*NOPW)*HNVT 
//   M[HZ]          HV native device              (OD*NIMP*POLY1*NOPW)-HNVT 
//   M[HP]          HV PMOS		                (OD*PIMP*POLY1*HVNW)  
//   M[FG]          Flash floating-gate device    (OD*RPO*FGT*MCEL*HVII*NOPW)-tfgt 
//   M[NF]          Flash control gate device     (OD*POLY1*MCEL*NOPW*NIMP)-tfgt 
//    
//   M[ST]          3.3V Select transistor nmos   ((NGATE*OD2-CELLH-CELLM)*CIRPO)   
//   M[RT]          3.3V Reset transistor nmos    (((NGATE*OD2-CELLM)*CELLH)*CIRPO)   
//   M[SF]          3.3V Source follower nmos     (((NGATE*OD2-CELLH)*CELLM)*CIRPO)   
//   M[nch_sf3]     I/O CIS source follower NMOS  (OD*POLY1*NIMP*OD2*PWELLX*CIRPO*CELLM) 
//   M[nch_rt3]     I/O CIS reset gate NMOS       (OD*POLY1*NIMP*OD2*PWELLX*CIRPO*CELLM*CELL_RS) 
//   M[nch_rs3]     I/O CIS row select NMOS       (OD*POLY1*NIMP*OD2*PWELLX*CIRPO*CELLM*CELL_SL) 
//   M[nch_tg3]     I/O CIS transfer gate NMOS    (OD*POLY1*NIMP*OD2*PWELLX*CIRPO*CELLM*CELLH**NPS*PPS*CELL_TX) 
//    
//   M[nch5_lvt]    5V IO LVT device              (NGATE*OD2-ESD*NLVT) 
//   M[nch5_lvt_60] 5V IO LVT device              (NGATE*OD2-ESD*NLVT*HV60DMY*PIMP) 
// 
// 
//   nch_hvnw_6t    Isolation LV NMOS             (NGATE*LDPW*HVNW*NWELL) 
//   pch_5t         Isolation LV PMOS             (PGATE*HVNW) 
//    
//   NCH_HV5_5VNW_ac  2T2C IOLDNMOS MACRO model   (POLY1*OD*OD2*NWELL*NLVT*NIMP*MTP_2T2C*H18VNWDMY) 
//    
//   D[DP]     	  CORE diode P+/NW              (DIODMY*OD*PIMP-OD2*NWELL)   
//   D[DN]	      CORE diode N+/PW              (DIODMY*OD*NIMP-OD2*PSUB)   
//   D[DW]	      CORE diode NW/PW              (DIODMY*OD*NIMP*NWELL-OD2)   
//   D[D1]	      I/O  diode P+/NW              (DIODMY*OD*PIMP*OD2*NWELL)   
//   D[D2]	      I/O  diode N+/PW              (DIODMY*OD*NIMP*OD2*PSUB)   
//   D[D3]	      I/O  diode NW/PW              (DIODMY*OD*NIMP*NWELL*OD2)   
//   D[DB]	      I/O  ESD diode                (ESD3DMY*OD*NIMP*RPO-NWELL-POLY1)  
//   D[ndio_m]      CORE diode N+/PW with VTMN    (DIODMY*OD*NIMP*VTMN*PSUB-OD2)  
//   D[pdio_m]      CORE diode P+/NW with VTMN    (DIODMY*OD*PIMP*VTMP*NWELL-OD2)  
//   D[ndio_3m]     I/O diode N+/PW with VTMN     (DIODMY*OD*NIMP*VTMN*PSUB*OD2) 
// 
//   D[PDIO_ull]    ULL CORE diode P+/NW          (DIODMY*OD*PIMP-OD2*OD3*ULLNW*) 
//   D[NDIO_ull]    ULL CORE diode N+/PW          (DIODMY*OD*NIMP-OD2*OD3*PSUB) 
//   D[NWDIO_ull]   ULL CORE diode NW/PW          (DIODMY*OD*NIMP*OD3*ULLNW-OD2) 
//   D[PDIO_ell]    ELL CORE diode P+/NW          (DIODMY*OD*PIMP-OD2*OD3*ULLNW*ELLDMY) 
//   D[NDIO_ell]    ELL CORE diode N+/PW          (DIODMY*OD*NIMP-OD2*OD3*PSUB*ELLDMY) 
//   D[NWDIO_ell]   ELL CORE diode NW/PW          (DIODMY*OD*NIMP*OD3*ULLNW-OD2*ELLDMY) 
//    
//   D[DZ]          3.3V CI/Psub photo diode      (NPS*CIRPO*OD*NIMP-PWELL*CI)    
//   D[DC]          3.3V NPS/Psub photo diode     (NPS*CIRPO*OD*NIMP-PWELL-CI-PPS)    
//   D[DY]          3.3V NPS+PPS/Psub photo diode (NPS*CIRPO*OD*NIMP-PWELL-CI*PPS)   
//   D[pindio_cis]    CIS PIN photo diode         (OD-NIMP-PIMP*PWELLX*CELLM*CELLH*NPS*PPS)  
//   D[nwdio_bg_cis]  NPS+PPS/Psub DIODE          (OD*OD2*CIRPO*BGP*BGN)  
// 
//   Q[NV]          CORE NPN-BJT		        	(BJTDMY*OD*NIMP-OD2*NWELL*DNW)  
//   Q[NV_mis]      CORE NPN-BJT mismatch model   (BJTDMY*LVSDMY*OD*NIMP-OD2*NWELL*DNW)  
// 
//   Q[PV]		  CORE PNP-BJT                  (BJTDMY*OD*PIMP-OD2*NWELL)   
//   Q[PV_mis]	  CORE PNP-BJT mismatch model   (BJTDMY*LVSDMY*OD*PIMP-OD2*NWELL)   
// 
//   Q[P1]		  I/O  PNP-BJT                  (BJTDMY*OD*PIMP*OD2*NWELL)   
// 
//   Q[pnp2_ull]	     CORE ULL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[pnp5_ull]	     CORE ULL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[pnp10_ull]	     CORE ULL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[npn2_ull]       CORE ULL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
//   Q[npn5_ull]       CORE ULL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
//   Q[npn10_ull]      CORE ULL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
//   Q[pnp2_ull_mis]   CORE ULL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[pnp5_ull_mis]   CORE ULL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[pnp10_ull_mis]  CORE ULL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3)  
//   Q[npn2_ull_mis]   CORE ULL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
//   Q[npn5_ull_mis]   CORE ULL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
//   Q[npn10_ull_mis]  CORE ULL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW) 
// 
//   Q[pnp2_ell]	     CORE ELL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[pnp5_ell]	     CORE ELL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[pnp10_ell]	     CORE ELL  PNP-BJT                       (BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[npn2_ell]       CORE ELL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
//   Q[npn5_ell]       CORE ELL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
//   Q[npn10_ell]      CORE ELL  NPN-BJT                       (BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
//   Q[pnp2_ell_mis]   CORE ELL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[pnp5_ell_mis]   CORE ELL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[pnp10_ell_mis]  CORE ELL  PNP-BJT mismatch model        (LVSDMY*BJTDMY*OD*PIMP-OD2*ULLNW*OD3*ELLDMY)  
//   Q[npn2_ell_mis]   CORE ELL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
//   Q[npn5_ell_mis]   CORE ELL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
//   Q[npn10_ell_mis]  CORE ELL  NPN-BJT mismatch model        (LVSDMY*BJTDMY*OD*NIMP-OD2*ULLNW*OD3*DNW*ELLDMY) 
// 
//   R[M1] 	  METAL1 resistor               (RMDMY1*METAL1)  
//   R[M2] 	  METAL2 resistor               (RMDMY2*METAL2)  
//   R[M3] 	  METAL3 resistor               (RMDMY3*METAL3)  
//   R[M4] 	  METAL4 resistor               (RMDMY4*METAL4)  
//   R[M5] 	  METAL5 resistor               (RMDMY5*METAL5)  
//   R[MT]	  METAL6 resistor               (RMDMY6*METAL6)  
// 
//   efuse    EFUSE resistor		            (POLY1*POFUSE*OD2*PIMP)    
//    
//   R[PR]      P+Poly resistor w/o Silicide  (RPDMYX*POLY1*PIMP*RPO*DMP2V-RFDUMMY-OD2-RPDMY5)   
//   R[NR]      N+Poly resistor w/o Silicide  (RPDMYX*POLY1*NIMP*RPO*DMN2V-RFDUMMY-OD2-RPDMY5)   
//   R[PS]      P+Poly resistor w/i Silicide  (RPDMYX*POLY1*PIMP-RPO-RFDUMMY)   
//   R[NS] 	  N+Poly resistor w/i Silicide  (RPDMYX*POLY1*NIMP-RPO-RFDUMMY)   
//   R[WR]      N-Well resistor under STI     (RWDMYX*NWELL-(OD*RPO)-OD2-RWDMY5)   
//   R[LR]      HRI high resistance poly R    (RPDMYX*POLY1*HRI*RLPPDMY*RPO-NIMP-PIMP-RFDUMMY)   
//   R[WO]      N-Well resistor under OD      (RWDMYX*NWELL*(OD*RPO)-OD2-RWDMY5)   
//   R[PD]      P+diff resistor w/o Silicide  (RPDMYX*NWELL*OD*PIMP*RPO-RFDUMMY*DMP2V-OD2-RPDMY5)   
//   R[ND] 	  N+diff resistor w/o Silicide  (RPDMYX*OD*NIMP*RPO-RFDUMMY*DMN2V-OD2-RPDMY5)   
//   R[PI] 	  P+diff resistor w/i Silicide  (RPDMYX*NWELL*OD*PIMP-RPO-RFDUMMY)   
//   R[NI]   	  N+diff resistor w/i Silicide  (RPDMYX*OD*NIMP-RPO-RFDUMMY)   
//    
//   rnwod_m         N-Well resistor under OD      (RWDMY1*NWELL*(OD*RPO)-OD2-RWDMY5)   
//   rnwsti_m        N-well resistor under STI     (RWDMY1*NWELL-(OD*RPO)-OD2-RWDMY5)   
//   rnpo1_dis       N+Poly resistor w/i Silicide(distributed)  (RPDMY1*POLY1*NIMP-RPO)   
//   rnpo1w_dis      N+Poly resistor w/i Silicide(distributed)  (RPDMY1*POLY1*NIMP-RPO)   
//   rppo1_dis       P+Poly resistor w/i Silicide(distributed)  (RPDMY1*POLY1*PIMP-RPO)   
//   rppo1w_dis      P+Poly resistor w/i Silicide(distributed)  (RPDMY1*POLY1*PIMP-RPO)   
//   rnodrpo_m       N+diff resistor w/o Silicide  (RPDMY1*OD*NIMP*RPO*DMN2V-OD2-RPDMY5)   
//   rpodrpo_m       P+diff resistor w/o Silicide  (RPDMY1*OD*PIMP*RPO*NWELL*DMP2V-OD2-RPDMY5)   
//   rnod_m          N+diff resistor w/i Silicide  (RPDMY1*OD*NIMP-RPO)   
//   rnodw_m         N+diff resistor w/i Silicide  (RPDMY1*OD*NIMP-RPO)  
//   rpod_m          P+diff resistor w/i Silicide  (RPDMY1*OD*PIMP-RPO*NWELL)   
