TEXT LAYER 41 ATTACH 41 metal2
PORT LAYER TEXT 41
TEXT LAYER 42 ATTACH 42 metal3
PORT LAYER TEXT 42
TEXT LAYER 43 ATTACH 43 metal4
PORT LAYER TEXT 43
TEXT LAYER 44 ATTACH 44 metal5
PORT LAYER TEXT 44
TEXT LAYER 45 ATTACH 45 metal6
PORT LAYER TEXT 45
#IFDEF Cu_RDL
  TEXT LAYER 159 ATTACH 159 metal7
  PORT LAYER TEXT 159
#ELSE
  LAYER metal7_text      477
  LAYER MAP 189 TEXTTYPE 103 477
  TEXT LAYER 477 ATTACH 477 metal7
  PORT LAYER TEXT 477
#ENDIF
#IFDEF RC_DECK
TEXT LAYER 47 ATTACH 47 poly
PORT LAYER TEXT 47
#ENDIF

#IFNDEF RC_DECK
LAYER MAP 47 TEXTTYPE 1 478
TEXT LAYER 478 ATTACH 478 poly
PORT LAYER TEXT 478
#ENDIF
//#############################################
//# LOGIC OPERATION POOL                      #
//#############################################

//Form BULK layer
DRC:1 = EXTENT
BULK  = SIZE DRC:1 BY 0.005

//* Define device --  N
POLY1 = POLY1i OR DPO 
RPDMYa = RPDMYX OR RPDMY1 
diff1 = OD OR DOD 
diff = diff1 NOT RODMY 
rp1 = RPDMYa NOT INTERACT diff 
p1rdum = rp1 INTERACT POLY1  //  poly1 resistor dummy
respa = POLY1 AND p1rdum 
resp = respa INTERACT POLY1i 
polya = POLY1 NOT resp  //  poly1 interconnect
MOMDMY = MOMDMY0 OR MOMDMY100 
MOMDMY_wo2t = MOMDMY NOT INTERACT MOMDMYBB  //  stacking MOS under cfmom_2t and cfmom_mx_4t  
polyb = polya NOT MOMDMY_wo2t  //  BULK of MOM
polyc = polyb NOT POFUSE 
tfgt = FGT AND POLY1 
poly = polyc NOT tfgt 
drdum = RPDMYa INTERACT diff  //  diff resistor dummy
resd = diff AND drdum  //  diff resistor layer
mdiff = diff NOT resd  //  diff interconnect
gate1 = poly AND mdiff 
DIODMYa1 = DIODMY OR DIO4TDMY 
DIODMYa = DIODMYa1 OR DIO3TDMY 
gate2 = gate1 NOT DIODMYa 
MOMDMYall_0 = MOMDMY0 OR MOMDMY1 
MOMDMYall_1 = MOMDMYall_0 OR MOMDMY2 
MOMDMYall_2 = MOMDMYall_1 OR MOMDMY3 
MOMDMYall_3 = MOMDMYall_2 OR MOMDMY4 
MOMDMYall_4 = MOMDMYall_3 OR MOMDMY5 
MOMDMYall_5 = MOMDMYall_4 OR MOMDMY6 
gate_all = gate2 NOT INTERACT MOMDMYall_5 
gate_rf1 = gate1 AND RFDUMMY1 
poly_rf1 = poly INTERACT CONT 
poly_rf = poly_rf1 INTERACT DRAIN 
gate_rf2 = gate_rf1 AND poly_rf 
VARDMYA1 = VARDMYX NOT VARG3 
VARDMYA2 = VARDMYA1 NOT VARG6 
VARDMY = VARDMYA2 NOT JVARD 
gate_rf3 = gate_rf2 NOT VARDMY 
gate_rf = gate_rf3 NOT JVARD 
gate_rf_mdiff = mdiff INTERACT gate_rf 
gate_norf = gate_all NOT gate_rf_mdiff 
HVDMY1 = HV40DMY OR HV60DMY 
HVDMY = HVDMY1 OR HVOX 
gate_lv1 = gate_norf NOT INTERACT HVDMY 
hvwell1 = NOPW INTERACT DNW 
hvwell2 = NOPW NOT hvwell1 
HVNWc = HVNWi NOT LDPW 
HVNWb = HVNWc NOT PDD_BCD 
RPDMY = RPDMYX NOT RPDMY1 
HVPB = HVPBi NOT INTERACT RPDMY 
HVNWa = HVNWb NOT HVPB 
RWDMYa = RWDMYX OR RWDMY1 
HVNW = HVNWa NOT RWDMYa 
hvwell3 = hvwell2 OR HVNW 
hvwell = hvwell3 NOT INTERACT HVDMY 
gate_lv = gate_lv1 NOT hvwell 
tngate1 = gate_lv AND NIMP 
tngate2 = tngate1 NOT MCEL 
nxwell1 = NWELL OR BASE_N 
nxwell2 = nxwell1 OR ULLNW 
nxwell = nxwell2 NOT RWDMYa 
tngate3 = tngate2 NOT nxwell 
tngate4 = tngate3 NOT CIRPO 
tngate4a = tngate4 NOT OD3 
tngate5 = tngate4a NOT lcesd1 
tngate6 = tngate5 NOT lcesd2 
tngate7 = tngate6 NOT LDPW 
tngate = tngate7 NOT MTDUM  //  4t nmos
ngate1 = tngate NOT OD2 
ngate3 = ngate1 NOT NTN 
ngate4 = ngate3 NOT DNW 
ngate5 = ngate4 NOT VTMN 
RFDUMMY = RFDUMMYX NOT RFDUMMY1 
ngate6 = ngate5 NOT RFDUMMY 
#IFDEF MACRO 
MAC = COPY OD
#ELSE
MAC = OD NOT (SIZE OD BY 0.005)
#ENDIF
ngate = ngate6 NOT MAC  //  1.8V Nominal VT NMOS

//***** Define connectivity/via layer -- tndiff ****
nthin1 = mdiff AND NIMP 
ydio_a = ESD3DMY AND OD 
ydio_c = SIZE ydio_a BY -0.2 
ydio_d = ydio_c AND NIMP 
ydio_e = ydio_d AND RPO 
ydio_f = ydio_e NOT NWELL 
ydio_g = ESD3DMY AND POLY1 
ydio_h = SIZE ydio_g BY 0.2 
ydio_i = ydio_f NOT ydio_h 
ydio_j = SIZE ydio_i BY -0.8 
ydio = SIZE ydio_j BY 0.6 
nthin = nthin1 NOT ydio  //  define N+ thin oxide
tndiff1 = nthin NOT gate_all  //  define N+ diffusion region
pthin = mdiff AND PIMP  //  define P+ thin oxide
tpdiff = pthin NOT gate_all  //  define P+ diffusion region
np_ovlp = tpdiff AND tndiff1 
dz_ring1 = np_ovlp AND RPO 
dz_ring = SIZE dz_ring1 BY 0.01 
tndiff2 = tndiff1 NOT dz_ring 
celdif1 = mdiff AND hvwell 
celdif2 = celdif1 AND MCEL  //  Hvdiff + MCell
celdif = celdif2 NOT RODMY 
fggate1 = FGT NOT tfgt 
fggate2 = fggate1 AND celdif 
fggate3 = fggate2 AND HVII 
fggate4 = fggate3 AND RPO 
fggate = fggate4 AND NOPW 
tmcdiff1 = celdif NOT fggate 
nfgate1 = POLY1 NOT tfgt 
nfgate2 = nfgate1 AND celdif 
nfgate3 = nfgate2 AND NOPW 
nfgate = nfgate3 AND NIMP  //  Poly + Mcel - overlap of Poly and FGT
tmcdiff = tmcdiff1 NOT nfgate 
tndiff = tndiff2 OR tmcdiff 

//***** Define connectivity/via layer -- psub ****
psub2_ring1 = SIZE PSUB2 BY 0.01 
psub2_ring = psub2_ring1 NOT PSUB2 
snbl = SIZE NBL BY 0.01 
iso_hvnwa = HVNWi NOT HVDMY 
ANWEL1 = nxwell OR iso_hvnwa 
ANWEL = ANWEL1 OR HVNW 
nbl_hvnw = snbl AND ANWEL 
ptsub1 = BULK NOT psub2_ring 
ptsub2 = ptsub1 NOT nbl_hvnw 
ptsub = ptsub2 INSIDE NBL 
nbl_hvnw_ring = nbl_hvnw INTERACT ptsub 
ppsub = psub2_ring OR nbl_hvnw_ring 
psuba = BULK NOT ppsub 
trwell = RWDMYa AND NWELL  //  
psubb = psuba NOT trwell 
rhvnw1 = HVNWa AND RWDMYX 
psubc = psubb NOT rhvnw1 
HVPWa = HVDMY NOT HVNW 
rhvpw1 = HVPWa AND RWDMYX 
psubd = psubc NOT rhvpw1 
psube = psubd NOT HVNWa 
psub = psube NOT nxwell 

//* Define device --  N1
nrgate1 = ngate3 AND DNW 
nrgate2 = nrgate1 NOT VTMN 
RWDMY = RWDMYX NOT RWDMY1 
HVPWb = HVPWa NOT RWDMY 
gate_hv = gate_norf INTERACT HVDMY  //  special for BCD12v
nld_r1 = gate_hv AND NIMP 
nld_r2 = nld_r1 INTERACT HVPB 
nld_r3 = nld_r2 AND HVNWi 
nld12_r1 = nld_r3 INTERACT NDD_BCD 
nld12_r2 = nld12_r1 NOT HVOX 
nld12g2_r1 = nld12_r1 INTERACT nld12_r2 
HVPWc = HVPWb NOT INTERACT nld12g2_r1 
nthin_hv1 = nthin INTERACT gate_hv
nthin_hv2 = EXPAND EDGE nthin_hv1 OUTSIDE BY 0.1
nthin_hv3 = nthin_hv2 INSIDE HVNW
nthin_hv4 = nthin_hv1 TOUCH EDGE nthin_hv3
nthin_hv5 = EXPAND EDGE nthin_hv4 OUTSIDE BY 2.0
nthin_hv = nthin OR nthin_hv5
nld14_r2 = poly AND nthin_hv 
nld14_r1 = nld_r3 NOT INTERACT NDD_BCD 
nld14_r3 = nld14_r2 INTERACT nld14_r1 
nld14_r4 = nld14_r3 INTERACT NDD_BCD 
nld14_r5 = nld14_r4 NOT HVOX 
nld14g2_r1 = nld14_r4 INTERACT nld14_r5 
HVPW = HVPWc NOT INTERACT nld14g2_r1 
nrgate3 = nrgate2 NOT HVPW 
nrgate4 = nrgate3 NOT RFDUMMY 
nrgate = nrgate4 NOT MAC  //  1.8V nominal VT NMOS on DNW

//* Define device --  ND
bngate1 = tngate AND OD2 
bngate1a = bngate1 NOT INTERACT H18VNWDMY 
bngate1b = bngate1a NOT NLVT 
bngate2 = bngate1b NOT NTN 
bngate3 = bngate2 NOT CAP_IMP 
bngate4 = bngate3 NOT DNW 
bngate5 = bngate4 NOT VTMN 
bngate6 = bngate5 NOT RFDUMMY 
bngate7 = bngate6 NOT VTDN 
bngate8 = bngate7 NOT VTHVDN 
bngate9 = bngate8 NOT ANALOGDMYi 
bngate = bngate9 NOT MAC  //  3.3/5V Nominal VT NMOS

//* Define device --  N2
bnrgate1 = bngate2 AND DNW 
bnrgate2 = bnrgate1 NOT VTMN  //  N2(nch3 or nch_5) should not have VTMN
bnrgate3 = bnrgate2 NOT RFDUMMY 
bnrgate4 = bnrgate3 NOT ANALOGDMYi 
bnrgate = bnrgate4 NOT MAC  //  3.3/5V nominal VT NMOS on DNW

//* Define device --  nch_ana33
bngate_ana33a = bngate1 AND ANALOGDMYi 
bngate_ana33b = bngate_ana33a NOT DNW 
bngate_ana33 = bngate_ana33b NOT MAC 

//* Define device --  nch_ana33_dnw
bngate_ana33b_dnw = bngate_ana33a AND DNW 
bngate_ana33_dnw = bngate_ana33b_dnw NOT MAC 

//* Define device --  NL
nlgate1 = ngate1 AND NTN 
nlgate2 = nlgate1 NOT RFDUMMY 
nlgate = nlgate2 NOT MAC  //  1.8V native NMOS

//* Define device --  NN
bnlgate1 = bngate1b AND NTN 
bnlgate2 = bnlgate1 NOT RFDUMMY 
bnlgate3 = bnlgate2 NOT INTERACT DMYLD 
bnlgate = bnlgate3 NOT MAC  //  3.3/5V native NMOS

//* Define device --  NA
mvt_ngate1 = ngate3 AND VTMN 
mvt_ngate2 = mvt_ngate1 NOT RFDUMMY 
mvt_ngate = mvt_ngate2 NOT MAC  //  1.8V medium VT NMOS

//* Define device --  NB
bmvt_ngate1 = bngate3 AND VTMN 
bmvt_ngate2 = bmvt_ngate1 NOT RFDUMMY 
bmvt_ngate = bmvt_ngate2 NOT MAC  //  3.3/5V medium VT NMOS

//* Define device --  P
tpgate1 = gate_lv AND PIMP 
tpgate2 = tpgate1 AND nxwell 
tpgate3 = tpgate2 NOT HVNWi 
tpgate3a = tpgate3 NOT ULLNW 
tpgate3b = tpgate3a NOT OD3 
tpgate = tpgate3b NOT MTDUM  //  4t pmos
pgate1 = tpgate NOT OD2 
pgate2 = pgate1 NOT VTMP 
pgate3 = pgate2 NOT RFDUMMY 
pgate = pgate3 NOT MAC  //  1.8V core normal pmos

//* Define device --  PD
bpgate1 = tpgate AND OD2 
bpgate2 = bpgate1 NOT VTMP 
bpgate4 = bpgate2 NOT RFDUMMY 
bpgate5 = bpgate4 NOT ANALOGDMYi 
bpgate = bpgate5 NOT MAC  //  3.3V Nominal VT PMOS

//* Define device --  pch_ana33
bpgate_ana33a = bpgate4 AND ANALOGDMYi 
bpgate_ana33 = bpgate_ana33a NOT MAC  //  3.3V Nominal VT PMOS

//* Define device --  PA
mvt_pgate1 = pgate1 AND VTMP 
mvt_pgate2 = mvt_pgate1 NOT RFDUMMY 
mvt_pgate = mvt_pgate2 NOT MAC  //  1.8V medium VT PMOS

//* Define device --  nch_mac
ngate_mac = ngate6 AND MAC  //  1.8V Nominal VT NMOS macro model

//* Define device --  nch_dnw_mac
nrgate_mac = nrgate4 AND MAC  //  1.8V nominal VT NMOS on DNW macro model

//* Define device --  mench
mvt_ngate_mac1 = mvt_ngate2 AND MAC  //  1.8V medium VT NMOS macro model
#IFDEF PROCESS_WO_MVTMOS_MACRO 
MAC_MVT = OD AND (SIZE OD BY 0.005)
#ELSE
MAC_MVT = OD NOT (SIZE OD BY 0.005)
#ENDIF

mvt_ngate_nomac = mvt_ngate_mac1 AND MAC_MVT 

//* Define device --  mench_mac
mvt_ngate_mac = mvt_ngate_mac1 NOT MAC_MVT 

//* Define device --  nanch_mac
nlgate_mac = nlgate2 AND MAC  //  1.8V native NMOS macro model

//* Define device --  pch_mac
pgate_mac = pgate3 AND MAC  //  mismatch 1.8V core normal pmos

//* Define device --  mepch
mvt_pgate_mac1 = mvt_pgate2 AND MAC  //  1.8V medium VT PMOS macro model
mvt_pgate_nomac = mvt_pgate_mac1 AND MAC_MVT 

//* Define device --  mepch_mac
mvt_pgate_mac = mvt_pgate_mac1 NOT MAC_MVT 

//* Define device --  nch3_mac
bngate_mac = bngate9 AND MAC 

//* Define device --  nch3_dnw_mac
bnrgate_mac = bnrgate4 AND MAC  //  3.3/5V nominal VT NMOS on DNW macro model

//* Define device --  nch_ana33_mac
bngate_ana33_mac = bngate_ana33b AND MAC 

//* Define device --  nch_ana33_dnw_mac
bngate_ana33_dnw_mac = bngate_ana33b_dnw AND MAC 

//* Define device --  mench3
bmvt_ngate_mac1 = bmvt_ngate2 AND MAC  //  3.3/5V medium VT NMOS macro model
bmvt_ngate_nomac = bmvt_ngate_mac1 AND MAC_MVT 

//* Define device --  mench3_mac
bmvt_ngate_mac = bmvt_ngate_mac1 NOT MAC_MVT 

//* Define device --  nanch3_mac
bnlgate_mac = bnlgate3 AND MAC  //  3.3/5V native NMOS macro model

//* Define device --  pch3_mac
bpgate_mac = bpgate5 AND MAC  //  3.3V Nominal VT PMOS macro model

//* Define device --  pch_ana33_mac
bpgate_ana33_mac = bpgate_ana33a AND MAC  //  3.3V Nominal VT PMOS macro model

//* Define device --  UN
nulgate1 = tngate4 AND OD3 
od2f1 = MCEL OR NOPW 
od2f = HVNW OR od2f1  //  thick oxide in flash
GOD2 = od2f OR OD2  //  thick and 3.3V oxide
nulgate2 = nulgate1 NOT GOD2 
nulgate3 = nulgate2 NOT MTDUM  //  4t ULL nmos
nulgate4 = nulgate3 NOT ELLDMY  //  1.8V ULL Nominal VT NMOS gate
nulgate = nulgate4 NOT MAC  //  1.8V ULL Nominal VT NMOS gate

//* Define device --  UP
pulgate1 = tpgate3 AND ULLNW 
pulgate2 = pulgate1 AND OD3 
pulgate3 = pulgate2 NOT GOD2 
pulgate4 = pulgate3 NOT MTDUM  //  4t ULL pmos 
pulgate5 = pulgate4 NOT ELLDMY  //  1.8V ULL Nominal VT PMOS gate
pulgate = pulgate5 NOT MAC  //  1.8V ULL Nominal VT PMOS gate

//* Define device --  nch_ull_mac
nulgate_mac = nulgate4 AND MAC  //  1.8V ULL Nominal VT NMOS gate mismatch model

//* Define device --  pch_ull_mac
pulgate_mac = pulgate5 AND MAC  //  1.8V ULL Nominal VT PMOS gate macro model

//* Define device --  nch_ell
nelgate4 = nulgate3 AND ELLDMY  //  1.8V ELL Nominal VT NMOS gate
nelgate = nelgate4 NOT MAC  //  1.8V ULL Nominal VT NMOS gate

//* Define device --  pch_ell
pelgate5 = pulgate4 AND ELLDMY  //  1.8V ULL Nominal VT PMOS gate
pelgate = pelgate5 NOT MAC  //  1.8V ULL Nominal VT PMOS gate

//* Define device --  nch_ell_mac
nelgate_mac = nelgate4 AND MAC  //  1.8V ULL Nominal VT NMOS gate mismatch model

//* Define device --  pch_ell_mac
pelgate_mac = pelgate5 AND MAC  //  1.8V ULL Nominal VT PMOS gate macro model

//* Define device --  nch5_lvt
bnngate1 = bngate1a AND NLVT  //  5.0V Low VT Devices
hvpw_guardring1 = tpdiff AND HVPW 
hvpw_guardring60 = hvpw_guardring1 AND HV60DMY 
bnngate_60a = HOLES hvpw_guardring60 INNER
bnngate = bnngate1 NOT INTERACT bnngate_60a 

//* Define device --  nch5_lvt_60
bnngate_60 = bnngate1 INTERACT bnngate_60a 

//***** Define connectivity/via layer -- nch_hvnw_6t_reg ****
LDPW_INT_NW = LDPW INTERACT NWELL 
nch_hvnw_6t_r1 = tngate1 AND LDPW_INT_NW 
nch_hvnw_6t_reg = nch_hvnw_6t_r1 AND HVNWi 

//***** Define connectivity/via layer -- iso_hvnw ****
iso_hvnw = iso_hvnwa NOT RWDMY 

//***** Define connectivity/via layer -- psub_under_hvnw ****
psub_term1 = psub NOT DNW 
psub_term2 = psub_term1 NOT HVNWi 
psub_term3 = psub_term2 NOT NBL 
nxwell_dnwa = nxwell INTERACT DNW 
nxwell_dnw = nxwell_dnwa NOT DNW 
psub_term = psub_term3 OR nxwell_dnw 
psub_under_hvnw = psub_term OR HVNWi 

//***** Define connectivity/via layer -- pch_5t_reg ****
pch_5t_reg1 = gate_lv1 AND PIMP 
hvnw_nw = NWELL AND HVNW  //  special for BCD12v process
pch_5t_reg2 = pch_5t_reg1 AND hvnw_nw 
pch_5t_reg = pch_5t_reg2 NOT MTDUM 

//* Define device -- diode DP
pdio_a = tpdiff AND DIODMY 
pdio_b = pdio_a NOT HIA_DUMMY 
pdio_c = pdio_b NOT hvwell 
pdio_d = pdio_c AND nxwell 
pdio_e = pdio_d NOT HVDMY 
pdio_f = pdio_e NOT VTMP 
pdio_g = pdio_f NOT OD3 
pdio_h = pdio_g NOT ULLNW 
pdio = pdio_h NOT OD2 

//* Define device -- diode D1
pdio_IO = pdio_h AND OD2 

//* Define device -- diode DN
ndio_a = tndiff AND DIODMY 
ndio_a1 = ndio_a NOT INTERACT PDD_BCD 
ndio_b = ndio_a1 NOT HIA_DUMMY 
ndio_c = ndio_b NOT hvwell 
ndio_d = ndio_c NOT nxwell 
ndio_e = ndio_d NOT HVDMY 
ndio_f = ndio_e NOT VTMN 
ndio_g = ndio_f NOT OD3 
ndio = ndio_g NOT OD2  //  1.8V N+/PW diode

//* Define device -- diode D2
ndio_IO = ndio_g AND OD2  //  I/O N+/PW diode

//* Define device -- diode DW
DIONW1 = DIODMY AND ANWEL 
DIONW2 = DIODMY AND HVNW 
DIONW3 = DIONW1 OR DIONW2 
DIONW4 = DIONW3 OUTSIDE tpdiff 
DIONW = DIONW4 INTERACT tndiff 
nwdio_a = nxwell AND DIONW 
nwdio_b = nwdio_a NOT hvwell 
nwdio_c = nwdio_b NOT INTERACT DNW 
nwdio_d = nwdio_c NOT ULLNW 
nwdio = nwdio_d NOT OD2  //  1.8V NW/PW diode

//* Define device -- diode D3
nwdio_IO = nwdio_d AND OD2  //  I/O NW/PW diode

//***** Define connectivity/via layer -- ydio_hole ****
ydio_hole = HOLES ydio 

//* Define device -- diode pdio_m
pdio_m1 = pdio_e AND VTMP 
pdio_m = pdio_m1 NOT OD2  //  1.8V Medium-Vt P+/NW diode

//* Define device -- diode ndio_m
ndio_m1 = ndio_e AND VTMN 
ndio_m = ndio_m1 NOT OD2  //  1.8V Medium-Vt N+/PW diode

//* Define device -- diode ndio_3m
ndio_IO_m = ndio_m1 AND OD2  //  I/O Medium-Vt N+/PW diode

//* Define device -- diode pdio_ull
pdio_ull1 = pdio_f AND OD3 
pdio_ull2 = pdio_ull1 AND ULLNW 
pdio_ull = pdio_ull2 NOT ELLDMY 

//* Define device -- diode ndio_ull
ndio_ull1 = ndio_f AND OD3 
ndio_ull = ndio_ull1 NOT ELLDMY 

//* Define device -- diode nwdio_ull
nwdio_ull1 = nwdio_c AND ULLNW 
nwdio_ull2 = nwdio_ull1 AND OD3 
nwdio_ull = nwdio_ull2 NOT ELLDMY 

//* Define device -- diode pdio_ell
pdio_ell = pdio_ull2 AND ELLDMY 

//* Define device -- diode ndio_ell
ndio_ell = ndio_ull1 AND ELLDMY 

//* Define device -- diode nwdio_ell
nwdio_ell = nwdio_ull2 AND ELLDMY 

//* Define device -- r M1
M1X = M1 OR DUM1 
M1Y = M1X NOT M1SLOT 
RMDMY1 = RMDMY1i OR RMDMY 
M1Z = M1Y AND RMDMY1 
mt1res = M1Z INTERACT M1  //  metal1 resistor

//***** Define connectivity/via layer -- metal1 ****
metal1 = M1Y NOT mt1res  //  metal1 interconnect

//* Define device -- r M2
M2X = M2 OR DUM2 
M2Y = M2X NOT M2SLOT 
RMDMY2 = RMDMY2i OR RMDMY 
M2Z = M2Y AND RMDMY2 
mt2res = M2Z INTERACT M2  //  metal2 resistor

//***** Define connectivity/via layer -- metal2 ****
metal2 = M2Y NOT mt2res  //  metal2 interconnect

//* Define device -- r M3
M3X = M3 OR DUM3 
M3Y = M3X NOT M3SLOT 
RMDMY3 = RMDMY3i OR RMDMY 
M3Z = M3Y AND RMDMY3 
mt3res = M3Z INTERACT M3  //  metal3 resistor

//***** Define connectivity/via layer -- metal3 ****
metal3 = M3Y NOT mt3res  //  metal3 interconnect

//* Define device -- r M4
M4X = M4 OR DUM4 
M4Y = M4X NOT M4SLOT 
RMDMY4 = RMDMY4i OR RMDMY 
M4Z = M4Y AND RMDMY4 
mt4res = M4Z INTERACT M4  //  metal4 resistor

//***** Define connectivity/via layer -- metal4 ****
metal4 = M4Y NOT mt4res  //  metal4 interconnect

//* Define device -- r M5
M5X = M5 OR DUM5 
M5Y = M5X NOT M5SLOT 
RMDMY5 = RMDMY5i OR RMDMY 
M5Z = M5Y AND RMDMY5 
mt5res = M5Z INTERACT M5  //  metal5 resistor

//***** Define connectivity/via layer -- metal5 ****
mt5x = M5Y NOT mt5res 
ind_dmy1 = RFDUMMY1 AND INDDMY 
ind_dmy2 = ind_dmy1 AND NTN 
ind_dmy = SIZE ind_dmy2 BY -0.005 
metal5 = mt5x NOT ind_dmy 

//* Define device -- xdev MT
M6X = M6 OR DUM6 
M6Y = M6X NOT M6SLOT 
RMDMY6 = RMDMY6i OR RMDMY 
M6Z = M6Y AND RMDMY6 
mt6res = M6Z INTERACT M6  //  metal6 resistor

//***** Define connectivity/via layer -- metal6 ****
mt6x = M6Y NOT mt6res 
metal6 = mt6x NOT ind_dmy 

//* Define device -- xdev efuse
poly_fuse1 = POLY1 AND POFUSE 
poly_fuse2 = poly_fuse1 AND OD2 
poly_fuse = poly_fuse2 AND PIMP 

//* Define device -- r LR
rpop = resp INTERACT RPO 
hrpop1 = rpop AND HRI 
hrpop2 = hrpop1 NOT NIMP 
hrpop3 = hrpop2 NOT PIMP  //  HRI high resistance poly resistor
hrpop4 = hrpop3 AND RLPPDMY 
hrpo1 = hrpop4 NOT RFDUMMY1 
hrpo2 = hrpo1 INTERACT POLY1 
hrpo3 = hrpo2 NOT INTERACT HRI3KDMY 
hrpo_2t = hrpo3 AND RPDMY 

//* Define device -- r WR
drpo = diff AND RPO 
nwsti1 = trwell NOT drpo 
nwsti2 = nwsti1 AND RWDMY 
#IFDEF PROCESS_WI_PURE5V_RES 
OD2_pure5v = OD2 AND (SIZE OD2 BY 0.005)
#ELSE
OD2_pure5v = OD2 NOT (SIZE OD2 BY 0.005)
#ENDIF

nwsti3 = nwsti2 NOT OD2_pure5v 
nwsti = nwsti3 NOT RWDMY5  //  2T NWell resistor unter STI

//* Define device -- r WO
nwod1 = trwell AND drpo 
nwod2 = nwod1 AND RWDMY 
nwod3 = nwod2 NOT OD2_pure5v 
nwod = nwod3 NOT RWDMY5  //  2T NWell resistor unter OD

//* Define device -- r PR
prpop1 = rpop AND PIMP 
prpop2 = prpop1 INTERACT DMP2V 
prpop3 = prpop2 NOT RFDUMMY 
prpop = prpop3 NOT RFDUMMY1 
rpporpo1 = prpop AND RPDMY 
rpporpo2 = rpporpo1 NOT OD2_pure5v 
rpporpo = rpporpo2 NOT RPDMY5  //  2T p+po resistor w/o silicide 

//* Define device -- r NR
nrpop1 = rpop AND NIMP 
nrpop2 = nrpop1 INTERACT DMN2V 
nrpop3 = nrpop2 NOT RFDUMMY 
nrpop = nrpop3 NOT RFDUMMY1 
rnporpo1 = nrpop AND RPDMY 
rnporpo2 = rnporpo1 NOT OD2_pure5v 
rnporpo = rnporpo2 NOT RPDMY5  //  2T n+po resistor w/o silicide 

//* Define device -- r PD
resdod = resd INTERACT OD 
rdop1 = resdod INTERACT RPO 
rdop = rdop1 NOT RFDUMMY 
prdop1 = rdop AND PIMP 
prdop2 = prdop1 INTERACT DMP2V 
prdop3 = prdop2 AND nxwell 
prdop3a = prdop3 NOT ULLNW 
prdop3b = prdop3a NOT OD3 
prdop4 = prdop3b AND RPDMY 
prdop5 = prdop4 NOT OD2_pure5v  //  
prdop = prdop5 NOT RPDMY5  //  2T P+OD resistor w/o silicide 

//* Define device -- r ND
nrdop1 = rdop AND NIMP 
nrdop2 = nrdop1 INTERACT DMN2V 
nrdop3 = nrdop2 NOT nxwell 
nrdop4 = nrdop3 AND RPDMY 
nrdop5 = nrdop4 NOT OD2_pure5v 
nrdop = nrdop5 NOT RPDMY5  //  2T N+OD resistor w/o silicide

//* Define device -- r PS2
rpip = resp NOT rpop 
prpip1 = rpip AND PIMP  //  p+po resistor w/i silicide
prpip2 = prpip1 NOT RFDUMMY 
prpip = prpip2 NOT RFDUMMY1 
rppoip_edge = prpip INSIDE EDGE POLY1 
rppoip1 = LENGTH rppoip_edge  >= 2  < 999999 
rppoip2 = prpip WITH EDGE rppoip1 
rppoipw2 = prpip NOT rppoip2 
rppoipw = rppoipw2 AND RPDMY 

//* Define device -- r PS1
rppoip = rppoip2 AND RPDMY 

//* Define device -- r NS2
nrpip1 = rpip AND NIMP  //  n+po resistor w/i silicide
nrpip2 = nrpip1 NOT RFDUMMY 
nrpip = nrpip2 NOT RFDUMMY1 
rnpoip_edge = nrpip INSIDE EDGE POLY1 
rnpoip1 = LENGTH rnpoip_edge  >= 2  < 999999 
rnpoip2 = nrpip WITH EDGE rnpoip1 
rnpoipw2 = nrpip NOT rnpoip2 
rnpoipw = rnpoipw2 AND RPDMY 

//* Define device -- r NS1
rnpoip = rnpoip2 AND RPDMY 

//* Define device -- r PI2
rdip = resdod NOT rdop 
prdip1 = rdip AND PIMP 
prdip = prdip1 AND nxwell  //  P+OD resistor w/i silicide
rpodip_edge = prdip INSIDE EDGE diff 
rpodip1 = LENGTH rpodip_edge  >= 2  < 99999999 
rpodip2 = prdip WITH EDGE rpodip1 
rpodipw2 = prdip NOT rpodip2 
rpodipw3 = rpodipw2 NOT ULLNW 
rpodipw4 = rpodipw3 NOT OD3 
rpodipw = rpodipw4 AND RPDMY 

//* Define device -- r PI1
rpodip3 = rpodip2 NOT ULLNW 
rpodip4 = rpodip3 NOT OD3 
rpodip = rpodip4 AND RPDMY 

//* Define device -- r NI2
nrdip1 = rdip AND NIMP 
nrdip = nrdip1 NOT nxwell  //  N+OD resistor w/i silicide
rnodip_edge = nrdip INSIDE EDGE diff 
rnodip1 = LENGTH rnodip_edge  >= 2  < 99999999 
rnodip2 = nrdip WITH EDGE rnodip1 
rnodipw2 = nrdip NOT rnodip2 
rnodipw = rnodipw2 AND RPDMY 

//* Define device -- r NI1
rnodip = rnodip2 AND RPDMY 

//* Define device -- xdev rnwod_m
nwod_3t1 = nwod1 AND RWDMY1 
nwod_3t2 = nwod_3t1 NOT OD2_pure5v 
nwod_3t = nwod_3t2 NOT RWDMY5  //  3T NWell resistor unter OD 

//* Define device -- xdev rnwsti_m
nwsti_3t1 = nwsti1 AND RWDMY1 
nwsti_3t2 = nwsti_3t1 NOT OD2_pure5v 
nwsti_3t = nwsti_3t2 NOT RWDMY5  //  3T NWell resitor unter STI

//* Define device -- xdev rpod_m
rpodip_3t = rpodip4 AND RPDMY1 

//* Define device -- xdev rpodw_m
rpodipw_3t = rpodipw4 AND RPDMY1 

//* Define device -- xdev rpodrpo_m
prdop_3t1 = prdop3b AND RPDMY1 
prdop_3t2 = prdop_3t1 NOT OD2_pure5v 
prdop_3t = prdop_3t2 NOT RPDMY5  //  3T P+OD resistor w/o silicide 

//* Define device -- xdev rnod_m
rnodip_3t = rnodip2 AND RPDMY1 

//* Define device -- xdev rnodw_m
rnodipw_3t = rnodipw2 AND RPDMY1 

//* Define device -- xdev rnodrpo_m
nrdop_3t1 = nrdop3 AND RPDMY1 
nrdop_3t2 = nrdop_3t1 NOT OD2_pure5v 
nrdop_3t = nrdop_3t2 NOT RPDMY5  //  3T N+OD resistor w/o silicide 

//* Define device -- xdev rppo1rpo_dis
rpporpo_3t1 = prpop AND RPDMY1 
rpporpo_3t2 = rpporpo_3t1 NOT OD2_pure5v 
rpporpo_3t = rpporpo_3t2 NOT RPDMY5  //  3T p+po resistor w/o silicide 

//***** Define connectivity/via layer -- poly_term ****
poly_term1 = POLY1 AND RPDMY1 
poly_term2 = SIZE poly_term1 BY 0.005 
poly_term = poly_term2 NOT poly_term1 

//* Define device -- xdev rppo1w_dis
rppoipw_3t = rppoipw2 AND RPDMY1 

//* Define device -- xdev rppo1_dis
rppoip_3t = rppoip2 AND RPDMY1 

//* Define device -- xdev rnpo1w_dis
rnpoipw_3t = rnpoipw2 AND RPDMY1 

//* Define device -- xdev rnpo1_dis
rnpoip_3t = rnpoip2 AND RPDMY1 

//* Define device -- xdev rnpo1rpo_dis
rnporpo_3t1 = nrpop AND RPDMY1 
rnporpo_3t2 = rnporpo_3t1 NOT OD2_pure5v 
rnporpo_3t = rnporpo_3t2 NOT RPDMY5  //  3T n+po resistor w/o silicide

//* Define device -- xdev rppolyhri_dis
hrpo_3t = hrpo3 AND RPDMY1 

//* Define device -- xdev rpod_ull
rpodip_ull1 = rpodip2 AND ULLNW 
rpodip_ull2 = rpodip_ull1 AND OD3 
rpodip_ull3 = rpodip_ull2 NOT ELLDMY 
rpodip_ull = rpodip_ull3 AND RPDMY 

//* Define device -- xdev rpodw_ull
rpodipw_ull1 = rpodipw2 AND ULLNW 
rpodipw_ull2 = rpodipw_ull1 AND OD3 
rpodipw_ull3 = rpodipw_ull2 NOT ELLDMY 
rpodipw_ull = rpodipw_ull3 AND RPDMY 

//* Define device -- xdev rpodrpo_ull
prdop_ull1 = prdop3 AND ULLNW 
prdop_ull2 = prdop_ull1 AND OD3 
prdop_ull3 = prdop_ull2 AND RPDMY 
prdop_ull4 = prdop_ull3 INTERACT OD 
prdop_ull = prdop_ull4 NOT ELLDMY  //  ULL P+OD resistor w/o silicide

//* Define device -- xdev rnwsti_ull
trwell1_ull = RWDMY AND ULLNW 
trwell2_ull = trwell1_ull AND OD3 
trwell3_ull = trwell2_ull NOT HVNW 
trwell_ull = trwell3_ull NOT RWDMY1 
lvdiff = diff NOT hvwell 
dfhr0 = lvdiff AND RPO 
dfhr1 = dfhr0 NOT hvwell 
nwsti_ull1 = trwell_ull NOT dfhr1 
nwsti_ull = nwsti_ull1 NOT ELLDMY  //  RWDMY*NWELL -RPO -diff --> nwsti in ULLNW

//* Define device -- xdev rnwod_ull
nwod_ull1 = trwell_ull AND dfhr1  //  RWDMY*NWELLRPOdiff --> nwod
nwod_ull = nwod_ull1 NOT ELLDMY  //  RWDMY*NWELLRPOdiff --> nwod in ULLNW

//* Define device -- xdev rpod_ull_m
rpodip_ull_3t = rpodip_ull3 AND RPDMY1 

//* Define device -- xdev rpodw_ull_m
rpodipw_ull_3t = rpodipw_ull3 AND RPDMY1 

//* Define device -- xdev rpodrpo_ull_m
prdop_ull_3t1 = prdop3 AND ULLNW 
prdop_ull_3t2 = prdop_ull_3t1 AND OD3 
prdop_ull_3t3 = prdop_ull_3t2 AND RPDMY1 
prdop_ull_3t4 = prdop_ull_3t3 INTERACT OD 
prdop_ull_3t = prdop_ull_3t4 NOT ELLDMY  //  ULL P+OD resistor w/o silicide

//* Define device -- xdev rnwod_ull_m
trwelld_ull = RWDMY1 AND ULLNW 
trwellc_ull = trwelld_ull AND OD3 
trwellb_ull = trwellc_ull NOT HVNW 
trwella_ull = trwellb_ull INTERACT OD  //  N-well resistor layer
nwoda_ull1 = trwella_ull AND dfhr1  //  RWDMY*NWELLRPOdiff --> nwod
nwod_ull_3t = nwoda_ull1 NOT ELLDMY  //  RWDMY*NWELLRPOdiff --> nwod in ULLNW

//* Define device -- xdev rnwsti_ull_m
nwstia_ull1 = trwellb_ull NOT dfhr1  //  RWDMY*NWELL -RPO -diff --> nwsti
nwsti_ull_3t = nwstia_ull1 NOT ELLDMY  //  RWDMY*NWELL -RPO -diff --> nwsti in ULLNW

//* Define device -- xdev rpod_ell
rpodip_ell1 = rpodip_ull2 AND ELLDMY 
rpodip_ell = rpodip_ell1 AND RPDMY 

//* Define device -- xdev rpodw_ell
rpodipw_ell1 = rpodipw_ull2 AND ELLDMY 
rpodipw_ell = rpodipw_ell1 AND RPDMY 

//* Define device -- xdev rpodrpo_ell
prdop_ell = prdop_ull4 AND ELLDMY 

//* Define device -- xdev rnwsti_ell
nwsti_ell = nwsti_ull1 AND ELLDMY  //  RWDMY*NWELL -RPO -diff --> nwsti in ELLNW

//* Define device -- xdev rnwod_ell
nwod_ell = nwod_ull1 AND ELLDMY  //  RWDMY*NWELLRPOdiff --> nwod in ELLNW

//* Define device -- xdev rpod_ell_m
rpodip_ell_3t = rpodip_ell1 AND RPDMY1 

//* Define device -- xdev rpodw_ell_m
rpodipw_ell_3t = rpodipw_ell1 AND RPDMY1 

//* Define device -- xdev rpodrpo_ell_m
prdop_ell_3t = prdop_ull_3t4 AND ELLDMY 

//* Define device -- xdev rnwod_ell_m
nwod_ell_3t = nwoda_ull1 AND ELLDMY  //  RWDMY*NWELLRPOdiff --> nwod in ELLNW

//* Define device -- xdev rnwsti_ell_m
nwsti_ell_3t = nwstia_ull1 AND ELLDMY  //  RWDMY*NWELL -RPO -diff --> nwsti in ELLNW

//* Define device -- xdev rppolyhri3k
hrpo4 = hrpo2 INTERACT HRI3KDMY 
lrpop3k_2t = hrpo4 AND RPDMY 

//* Define device -- xdev rppolyhri3k_dis
lrpop3k_3t = hrpo4 AND RPDMY1 

//* Define device -- xdev nvmrpodrpo
prdop_nvm1 = prdop1 NOT INTERACT DMP2V 
prdop_nvm2 = prdop_nvm1 AND nxwell 
prdop_nvm3 = prdop_nvm2 NOT ULLNW 
prdop_nvm4 = prdop_nvm3 NOT OD3 
prdop_nvm5 = prdop_nvm4 NOT RPDMY5 
prdop_nvm = prdop_nvm5 AND RPDMY 

//* Define device -- xdev nvmrpodrpo_m
prdop_3t_nvm = prdop_nvm5 AND RPDMY1 

//* Define device -- xdev rhim
rhim_reg = MSi INTERACT M0 

//* Define device -- xdev PV2
ttdiff = tpdiff AND BJTDMY 
nbase_a = nxwell NOT INTERACT DNW 
nbase_b = nbase_a NOT INTERACT NBL 
nbase_gen1 = nbase_b AND BJTDMY 
nbase_gen2 = nbase_gen1 NOT OD3 
nbase_gen = nbase_gen2 NOT ULLNW 
nbase = nbase_gen NOT OD2  //  define 1.8V BJT[PV] base terminal
emit_temp1 = ttdiff AND nbase  //  define 1.8V BJT[PV] emitter
emit = emit_temp1 NOT hvwell 
emit2_temp = AREA emit  > 3.999  < 4.001 
emit2 = emit2_temp NOT LVSDMY  // define Q[PV]	   pnp2      CORE PNP-BJT

//***** Define connectivity/via layer -- coll ****
collsur = psub TOUCH nbase 
coll1a = collsur OR nbase  //   define BJT[PV] collector
collsura = collsur TOUCH emit 
coll1b = coll1a NOT collsura 
coll = coll1b NOT emit  //   define pnp collector

//* Define device -- xdev PV5
emit5_temp = AREA emit  > 24.999  < 25.001 
emit5 = emit5_temp NOT LVSDMY  // define Q[PV]	   pnp5	     CORE PNP-BJT

//* Define device -- xdev PV10
emit10_temp = AREA emit  > 99.999  < 100.001 
emit10 = emit10_temp NOT LVSDMY  // define Q[PV]     pnp10     CORE PNP-BJT

//* Define device -- xdev P12
nbase_od2 = nbase_gen INTERACT OD2  //  define 3.3V BJT[P1] base terminal
emit_od2_temp1 = ttdiff AND nbase_od2  //  define 3.3V BJT[P1] emitter
emit_od2 = emit_od2_temp1 NOT hvwell 
iemit2_temp1 = AREA emit_od2  > 3.999  < 4.001 
iemit2_temp = iemit2_temp1 NOT INTERACT RPO 
iemit2 = iemit2_temp NOT LVSDMY  // define Q[P1]     pnp2_5      IO   PNP-BJT

//***** Define connectivity/via layer -- coll_od2 ****
collsur_3 = psub TOUCH nbase_od2 
coll2a = collsur_3 OR nbase_od2  //   define BJT[PV] collector
collsurb = collsur_3 TOUCH emit_od2 
coll2b = coll2a NOT collsurb 
coll_od2 = coll2b NOT emit_od2  //   define pnp collector

//* Define device -- xdev P15
iemit5_temp1 = AREA emit_od2  > 24.999  < 25.001 
iemit5_temp = iemit5_temp1 NOT INTERACT RPO 
iemit5 = iemit5_temp NOT LVSDMY  // define Q[P1]     pnp5_5      IO   PNP-BJT

//* Define device -- xdev P110
iemit10_temp1 = AREA emit_od2  > 99.999  < 100.001 
iemit10_temp = iemit10_temp1 NOT INTERACT RPO 
iemit10 = iemit10_temp NOT LVSDMY  // define Q[P1]     pnp10_5     IO   PNP-BJT

//* Define device -- xdev NV2
npnrg_dnw1 = DNW AND BJTDMY 
npnrg_dnw = npnrg_dnw1 NOT HVDMY 
npnrg_nbl1 = NBL AND BJTDMY 
npnrg_nbl = npnrg_nbl1 NOT HVDMY 
npnrg = npnrg_dnw OR npnrg_nbl 
nndiff = tndiff AND npnrg 
pbase_gen1 = psub AND npnrg  // define 1.8V BJT[NV] base terminal
pbase_gen = pbase_gen1 INTERACT nxwell  // define 1.8V BJT[NV] base terminal
nemit_gen1 = nndiff AND pbase_gen  // define 1.8V BJT[NV] emitter
nemit_gen2 = nemit_gen1 NOT hvwell 
nemit_gen = nemit_gen2 NOT OD3 
nemit = nemit_gen NOT OD2 
nemit2_temp = AREA nemit  > 3.999  < 4.001 
nemit2 = nemit2_temp NOT LVSDMY  // define Q[NV]     npn2	 CORE NPN-BJT

//***** Define connectivity/via layer -- ncoll ****
ncollrg1 = nxwell AND npnrg 
ncollrg = ncollrg1 NOT ULLNW 
pbase = pbase_gen NOT OD2 
ncoll1 = ncollrg TOUCH pbase 
ncoll = ncoll1 OR pbase  // define 1.8V BJT[NV] collector

//* Define device -- xdev NV5
nemit5_temp = AREA nemit  > 24.999  < 25.001 
nemit5 = nemit5_temp NOT LVSDMY  // define Q[NV]     npn5      CORE NPN-BJT

//* Define device -- xdev NV10
nemit10_temp = AREA nemit  > 99.999  < 100.001 
nemit10 = nemit10_temp NOT LVSDMY  // define Q[NV]     npn10     CORE NPN-BJT

//* Define device -- xdev PV2_mis
emit2_mis = emit2_temp AND LVSDMY  // define Q[PV_mis] pnp2_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev PV5_mis
emit5_mis = emit5_temp AND LVSDMY  // define Q[PV_mis] pnp5_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev PV10_mis
emit10_mis = emit10_temp AND LVSDMY  // define Q[PV_mis] pnp10_mis CORE PNP-BJT mismatch model

//* Define device -- xdev NV2_mis
nemit2_mis = nemit2_temp AND LVSDMY  // define Q[NV_mis] npn2_mis  CORE NPN-BJT

//* Define device -- xdev NV5_mis
nemit5_mis = nemit5_temp AND LVSDMY  // define Q[NV_mis] npn5_mis  CORE NPN-BJT

//* Define device -- xdev NV10_mis
nemit10_mis = nemit10_temp AND LVSDMY  // define Q[NV_mis] npn10_mis CORE NPN-BJT

//* Define device -- xdev pnp2_ull
ull_nbase_gen2 = nbase_gen1 AND OD3 
ull_nbase_gen3 = ull_nbase_gen2 AND ULLNW 
ull_nbase_gen = ull_nbase_gen3 NOT ELLDMY 
ull_nbase = ull_nbase_gen NOT OD2  //  define 1.8V ULL BJT base terminal
ull_emit_temp1 = ttdiff AND ull_nbase  //  define 1.8V ULL BJT emitter
ull_emit = ull_emit_temp1 NOT hvwell 
ull_emit2_temp = AREA ull_emit  > 3.999  < 4.001 
ull_emit2 = ull_emit2_temp NOT LVSDMY  // define Q[PV]	   pnp2      CORE PNP-BJT

//***** Define connectivity/via layer -- ull_coll ****
ull_collsur = psub TOUCH ull_nbase 
ull_coll1a = ull_collsur OR ull_nbase  //   define BJT[PV] collector
ull_collsura = ull_collsur TOUCH ull_emit 
ull_coll1b = ull_coll1a NOT ull_collsura 
ull_coll = ull_coll1b NOT ull_emit  //   define pnp collector

//* Define device -- xdev pnp5_ull
ull_emit5_temp = AREA ull_emit  > 24.999  < 25.001 
ull_emit5 = ull_emit5_temp NOT LVSDMY  // define Q[PV]	   pnp5	     CORE PNP-BJT

//* Define device -- xdev pnp10_ull
ull_emit10_temp = AREA ull_emit  > 99.999  < 100.001 
ull_emit10 = ull_emit10_temp NOT LVSDMY  // define Q[PV]     pnp10     CORE PNP-BJT

//* Define device -- xdev npn2_ull
ull_nemit_gen1 = nemit_gen2 AND OD3 
ull_nemit_gen = ull_nemit_gen1 NOT ELLDMY 
ull_nemit = ull_nemit_gen NOT OD2 
ull_nemit2_temp = AREA ull_nemit  > 3.999  < 4.001 
ull_nemit2 = ull_nemit2_temp NOT LVSDMY  // define ULL  npn2	    CORE NPN-BJT

//***** Define connectivity/via layer -- ull_ncoll ****
ull_ncollrg1 = ncollrg1 AND ULLNW 
ull_ncollrg = ull_ncollrg1 NOT ELLDMY 
ull_ncoll1 = ull_ncollrg TOUCH pbase 
ull_ncoll = ull_ncoll1 OR pbase  // define 1.8V BJT[NV] collector

//* Define device -- xdev npn5_ull
ull_nemit5_temp = AREA ull_nemit  > 24.999  < 25.001 
ull_nemit5 = ull_nemit5_temp NOT LVSDMY  // define ULL  npn5      CORE NPN-BJT

//* Define device -- xdev npn10_ull
ull_nemit10_temp = AREA ull_nemit  > 99.999  < 100.001 
ull_nemit10 = ull_nemit10_temp NOT LVSDMY  // define ULL  npn10     CORE NPN-BJT

//* Define device -- xdev pnp2_ull_mis
ull_emit2_mis = ull_emit2_temp AND LVSDMY  // define Q[PV_mis] pnp2_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev pnp5_ull_mis
ull_emit5_mis = ull_emit5_temp AND LVSDMY  // define Q[PV_mis] pnp5_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev pnp10_ull_mis
ull_emit10_mis = ull_emit10_temp AND LVSDMY  // define Q[PV_mis] pnp10_mis CORE PNP-BJT mismatch model

//* Define device -- xdev npn2_ull_mis
ull_nemit2_mis = ull_nemit2_temp AND LVSDMY  // define ULL  npn2_mis  CORE NPN-BJT

//* Define device -- xdev npn5_ull_mis
ull_nemit5_mis = ull_nemit5_temp AND LVSDMY  // define ULL  npn5_mis  CORE NPN-BJT

//* Define device -- xdev npn10_ull_mis
ull_nemit10_mis = ull_nemit10_temp AND LVSDMY  // define ULL  npn10_mis CORE NPN-BJT

//* Define device -- xdev pnp2_ell
ell_nbase_gen = ull_nbase_gen3 AND ELLDMY 
ell_nbase = ell_nbase_gen NOT OD2  //  define 1.8V ELL BJT base terminal
ell_emit_temp1 = ttdiff AND ell_nbase  //  define 1.8V ELL BJT emitter
ell_emit = ell_emit_temp1 NOT hvwell 
ell_emit2_temp = AREA ell_emit  > 3.999  < 4.001 
ell_emit2 = ell_emit2_temp NOT LVSDMY  // define Q[PV]	   pnp2      CORE PNP-BJT

//***** Define connectivity/via layer -- ell_coll ****
ell_collsur = psub TOUCH ell_nbase 
ell_coll1a = ell_collsur OR ell_nbase  //   define BJT[PV] collector
ell_collsura = ell_collsur TOUCH ell_emit 
ell_coll1b = ell_coll1a NOT ell_collsura 
ell_coll = ell_coll1b NOT ell_emit  //   define pnp collector

//* Define device -- xdev pnp5_ell
ell_emit5_temp = AREA ell_emit  > 24.999  < 25.001 
ell_emit5 = ell_emit5_temp NOT LVSDMY  // define Q[PV]	   pnp5	     CORE PNP-BJT

//* Define device -- xdev pnp10_ell
ell_emit10_temp = AREA ell_emit  > 99.999  < 100.001 
ell_emit10 = ell_emit10_temp NOT LVSDMY  // define Q[PV]     pnp10     CORE PNP-BJT

//* Define device -- xdev npn2_ell
ell_nemit_gen = ull_nemit_gen1 AND ELLDMY 
ell_nemit = ell_nemit_gen NOT OD2 
ell_nemit2_temp = AREA ell_nemit  > 3.999  < 4.001 
ell_nemit2 = ell_nemit2_temp NOT LVSDMY  // define ell  npn2	    CORE NPN-BJT

//***** Define connectivity/via layer -- ell_ncoll ****
ell_ncollrg = ull_ncollrg1 AND ELLDMY 
ell_ncoll1 = ell_ncollrg TOUCH pbase 
ell_ncoll = ell_ncoll1 OR pbase 

//* Define device -- xdev npn5_ell
ell_nemit5_temp = AREA ell_nemit  > 24.999  < 25.001 
ell_nemit5 = ell_nemit5_temp NOT LVSDMY  // define ell  npn5      CORE NPN-BJT

//* Define device -- xdev npn10_ell
ell_nemit10_temp = AREA ell_nemit  > 99.999  < 100.001 
ell_nemit10 = ell_nemit10_temp NOT LVSDMY  // define ell  npn10     CORE NPN-BJT

//* Define device -- xdev pnp2_ell_mis
ell_emit2_mis = ell_emit2_temp AND LVSDMY  // define Q[PV_mis] pnp2_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev pnp5_ell_mis
ell_emit5_mis = ell_emit5_temp AND LVSDMY  // define Q[PV_mis] pnp5_mis  CORE PNP-BJT mismatch model

//* Define device -- xdev pnp10_ell_mis
ell_emit10_mis = ell_emit10_temp AND LVSDMY  // define Q[PV_mis] pnp10_mis CORE PNP-BJT mismatch model

//* Define device -- xdev npn2_ell_mis
ell_nemit2_mis = ell_nemit2_temp AND LVSDMY  // define ell  npn2_mis  CORE NPN-BJT

//* Define device -- xdev npn5_ell_mis
ell_nemit5_mis = ell_nemit5_temp AND LVSDMY  // define ell  npn5_mis  CORE NPN-BJT

//* Define device -- xdev npn10_ell_mis
ell_nemit10_mis = ell_nemit10_temp AND LVSDMY  // define ell  npn10_mis CORE NPN-BJT

//* Define device -- xdev C1
mim_block = CTM5 AND M5 
capm5a = mim_block INTERACT VIA5i 
capm5b = capm5a NOT RFDUMMY 
capm5ud1 = capm5b NOT RFDUMMYUD 
capm5ud2 = capm5ud1 NOT CTMDMY 
capm5_ud = capm5ud2 AND CTMDMYUD 
capm5_ud_2t = capm5_ud NOT CTMDMY_3t 
CTMDMYall = CTMDMY OR CTMDMYUD 
capdmy1p0a = CTMDMYall NOT CTMDMY1p5 
capdmy1p0 = capdmy1p0a NOT CTMDMY2p0  // ctmdmy1p0
capm5_1p0_ud1 = capm5_ud_2t INTERACT capdmy1p0 
capm5_1p0_ud2 = capm5_1p0_ud1 NOT HLMIMCAP1P0 
RFDUMMYall = RFDUMMY1 OR RFDUMMYUD 
capm5c = capm5b NOT RFDUMMYall 
capm5d = capm5c AND CTMDMY 
capm5 = capm5d NOT CTMDMYUD 
capm5_2t = capm5 NOT CTMDMY_3t 
capm5_1p01 = capm5_2t INTERACT capdmy1p0 
capm5_1p0 = capm5_1p01 NOT HLMIMCAP1P0 
capm5_1p0_udc = capm5_1p0_ud2 OR capm5_1p0 

//***** Define connectivity/via layer -- ctm ****
ctm = COPY CTM5 

//* Define device -- xdev C2
capdmy2p0a = CTMDMYall NOT CTMDMY1p0 
capdmy2p0b = capdmy2p0a NOT CTMDMY1p5 
capdmy2p0 = capdmy2p0b AND CTMDMY2p0  // ctmdmy2p0
capm5_2p0_ud1 = capm5_ud_2t INTERACT capdmy2p0 
capm5_2p0 = capm5_2t INTERACT capdmy2p0 
capm5_2p0_udc = capm5_2p0_ud1 OR capm5_2p0 

//* Define device -- xdev mimcap_1p5
capdmy1p5a = CTMDMYall NOT CTMDMY1p0 
capdmy1p5b = capdmy1p5a NOT CTMDMY2p0 
capdmy1p5 = capdmy1p5b AND CTMDMY1p5  // ctmdmy1p5
capm5_1p5_ud1 = capm5_ud_2t INTERACT capdmy1p5 
capm5_1p5 = capm5_2t INTERACT capdmy1p5 
capm5_1p5_udc = capm5_1p5_ud1 OR capm5_1p5 

//* Define device -- xdev mimcap_3t
capm5_3t = capm5 AND CTMDMY_3t 
capm5_1p0_3tc1 = capm5_3t INTERACT capdmy1p0 
capm5_1p0_3tc = capm5_1p0_3tc1 NOT HLMIMCAP1P0 

//***** Define connectivity/via layer -- mim_term ****
mim_term = SIZE capm5_3t BY 0.005 

//* Define device -- xdev mimcap_2p0_3t
capm5_2p0_3tc = capm5_3t INTERACT capdmy2p0 

//* Define device -- xdev mimcap_1p0_sin
capm5_1p0_ud = capm5_1p0_ud2 OR capm5_1p0 

//* Define device -- xdev mimcap_2p0_sin
capm5_2p0_ud = capm5_2p0_ud1 OR capm5_2p0 

//* Define device -- xdev mimcap_1p5_sin
capm5_1p5_ud = capm5_1p5_ud1 OR capm5_1p5 

//* Define device -- xdev mimcap_1p0_sin_3t
capm5_1p0_3t1 = capm5_3t INTERACT capdmy1p0 
capm5_1p0_3t = capm5_1p0_3t1 NOT HLMIMCAP1P0 

//* Define device -- xdev mimcap_2p0_sin_3t
capm5_2p0_3t = capm5_3t INTERACT capdmy2p0 

//* Define device -- xdev mimcap_1p5_sin_3t
capm5_1p5_3t = capm5_3t INTERACT capdmy1p5 

//* Define device -- xdev mimcap_1p0_sin_hl
capm5_1p0_hla = capm5a AND CTMDMY 
capm5_1p0_hl_2ta = capm5_1p0_hla NOT CTMDMY_3t 
capm5_1p0_hl_2t = capm5_1p0_hl_2ta AND HLMIMCAP1P0  //  2T HL M5*CTM6 capacitance is 1.0fF per unit area.

//* Define device -- xdev mimcap_1p0_sin_hl_3t
capm5_1p0_hl_3ta = capm5_1p0_hla AND CTMDMY_3t 
capm5_1p0_hl_3t = capm5_1p0_hl_3ta AND HLMIMCAP1P0  //  3T HL M5*CTM6 capacitance is 1.0fF per unit area.

//* Define device -- xdev mimcap_2p0_sin_3ds
cmm_capma5 = CMM5 AND M5 
cmm_capmb5 = cmm_capma5 INTERACT CMMDMY2p0 
cmm_capmc5 = cmm_capmb5 NOT INTERACT CTMDMY2p0 
cmm_capm5 = cmm_capmc5 NOT INTERACT ctm 
capm5_2p0_sin_3ds = cmm_capm5 NOT INTERACT CMM_3T 

//***** Define connectivity/via layer -- cmm ****
cmm = COPY CMM5 

//* Define device -- xdev mimcap_2p0_sin_3ds_3t
capm5_2p0_sin_3ds_3t = cmm_capm5 INTERACT CMM_3T 

//***** Define connectivity/via layer -- mim_term_sandwich_3t ****
mim_block_cmm = CMM5 AND M5 
capm3a_sandwich5a = mim_block_cmm INTERACT VIA5i 
capm3a_sandwich5 = capm3a_sandwich5a AND CMMDMY2p0 
capm3a_sandwich5_3t = capm3a_sandwich5 AND CMM_3T 
mim_term_sandwich_3t = SIZE capm3a_sandwich5_3t BY 0.005 

//* Define device -- xdev mimcap_4p0_sin_3dshs
ctm_cmm_capma5 = cmm_capmb5 INTERACT capm5a 
ctm_cmm_capm5 = ctm_cmm_capma5 INTERACT CTMDMY2p0 
ctm_cmm_capm5_2t = ctm_cmm_capm5 NOT INTERACT CMM_3T 
capm5_4p0_sin_3dshs = ctm_cmm_capm5_2t INTERACT CMM_SH 

//* Define device -- xdev mimcap_4p0_sin_3dshs_3t
ctm_cmm_capm5_3t = ctm_cmm_capm5 INTERACT CMM_3T 
capm5_4p0_sin_3dshs_3t = ctm_cmm_capm5_3t INTERACT CMM_SH 

//* Define device -- xdev nmoscap
nthin_var1 = nthin AND nxwell 
nthin_var2 = nthin_var1 AND VARDMY 
nthin_var3 = nthin_var2 NOT RFDUMMY 
nthin_var4 = nthin_var3 NOT RFDUMMY1 
nthin_var5 = nthin_var4 INTERACT tngate1 
nthin_var6 = nthin_var5 NOT OD2  // Myron
nthin_var = nthin_var6 NOT VTDN  // Myron
nmoscap_reg = nthin_var NOT LVSDMY 

//***** Define connectivity/via layer -- vargt ****
vargt1 = tngate1 AND nxwell 
vargt2 = vargt1 AND VARDMY 
vargt3 = vargt2 NOT RFDUMMY 
vargt4 = vargt3 NOT RFDUMMY1 
vargt = vargt4 NOT OD2  // 1.8V baseband varactor

//* Define device -- xdev nmoscap_mis
nmoscap_mis_reg = nthin_var AND LVSDMY 

//* Define device -- xdev nmoscap_33
nthin_bvar = nthin_var5 AND OD2 
nmoscap_33_reg = nthin_bvar NOT LVSDMY 

//***** Define connectivity/via layer -- bvargt ****
bvargt = vargt4 AND OD2  // 3.3V baseband varactor

//* Define device -- xdev nmoscap_33_mis
nmoscap_33_mis_reg = nthin_bvar INTERACT LVSDMY 

//* Define device -- xdev nmos_rf
nrgate_rf1 = gate_rf AND NIMP 
nrgate_rf2 = nrgate_rf1 NOT NTN 
nrgate_rf3 = nrgate_rf2 NOT VTMN 
nrgate_rf4 = nrgate_rf3 AND DNW 
nrgate_rf = nrgate_rf4 NOT OD2 
nrgate_rf4t = nrgate_rf AND RFDUMMY1  //  1.8V RF NMOS 4 terminals
nrgate_4t_nthin_1 = nthin INTERACT nrgate_rf4t 
nrgate_4t_nthin_2 = nrgate_4t_nthin_1 NOT INTERACT asym_rf 
nrgate_4t_nthin = nrgate_4t_nthin_2 NOT RFDUMMY6T  //  nmos_rf

//***** Define connectivity/via layer -- d_tndiff ****
d_tndiff = tndiff AND DRAIN 

//***** Define connectivity/via layer -- s_tndiff ****
s_tndiff1 = tndiff NOT d_tndiff 
s_tndiff = s_tndiff1 INTERACT gate_rf 

//* Define device -- xdev nmos_rf33
bnrgate_rf = nrgate_rf4 AND OD2 
bnrgate_rf4t = bnrgate_rf AND RFDUMMY1  //  3.3V RF NMOS 4 terminals
bnrgate_4t_nthin_1 = nthin INTERACT bnrgate_rf4t 
bnrgate_4t_nthin_2 = bnrgate_4t_nthin_1 NOT INTERACT asym_rf 
bnrgate_4t_nthin = bnrgate_4t_nthin_2 NOT RFDUMMY6T  //  nmos_rf33

//* Define device -- xdev nmos_rf_6t
nrgate_6t_nthin = nrgate_4t_nthin_2 AND RFDUMMY6T  //  nmos_rf_6t

//* Define device -- xdev nmos_rf33_6t
bnrgate_6t_nthin = bnrgate_4t_nthin_2 AND RFDUMMY6T  //  nmos_rf33_6t

//* Define device -- xdev pmos_rf
pgate_rf1 = gate_rf AND PIMP 
pgate_rf2 = pgate_rf1 NOT VTMP 
pgate_rf3 = pgate_rf2 INTERACT nxwell 
pgate_rf = pgate_rf3 NOT OD2 
pgate_rf4t1 = pgate_rf AND RFDUMMY1 
pgate_rf4t = pgate_rf4t1 AND DNW  //  1.8V RF PMOS 4 terminals with DNW
pgate_4t_pthin_1 = pthin INTERACT pgate_rf4t 
pgate_4t_pthin_2 = pgate_4t_pthin_1 NOT INTERACT asym_rf 
pgate_4t_pthin = pgate_4t_pthin_2 NOT RFDUMMY5T  //  pmos_rf

//***** Define connectivity/via layer -- d_tpdiff ****
d_tpdiff = tpdiff AND DRAIN 

//***** Define connectivity/via layer -- s_tpdiff ****
s_tpdiff1 = tpdiff NOT d_tpdiff 
s_tpdiff = s_tpdiff1 INTERACT gate_rf 

//* Define device -- xdev pmos_rf_nw
pgate_rf4t_nw = pgate_rf4t1 NOT DNW  //  1.8V RF PMOS 4 terminals without DNW
pgate_4t_pthin_nw_1 = pthin INTERACT pgate_rf4t_nw 
pgate_4t_pthin_nw_2 = pgate_4t_pthin_nw_1 NOT INTERACT asym_rf 
pgate_4t_pthin_nw = pgate_4t_pthin_nw_2 NOT RFDUMMY5T  //  pmos_rf_nw

//* Define device -- xdev pmos_rf33
bpgate_rf = pgate_rf3 AND OD2 
bpgate_rf4t1 = bpgate_rf AND RFDUMMY1 
bpgate_rf4t = bpgate_rf4t1 AND DNW  //  3.3V RF PMOS 4 terminals with DNW
bpgate_4t_pthin_1 = pthin INTERACT bpgate_rf4t 
bpgate_4t_pthin_2 = bpgate_4t_pthin_1 NOT INTERACT asym_rf 
bpgate_4t_pthin = bpgate_4t_pthin_2 NOT RFDUMMY5T  //  pmos_rf33

//* Define device -- xdev pmos_rf33_nw
bpgate_rf4t_nw = bpgate_rf4t1 NOT DNW  //  3.3V RF PMOS 4 terminals without DNW
bpgate_4t_pthin_nw_1 = pthin INTERACT bpgate_rf4t_nw 
bpgate_4t_pthin_nw_2 = bpgate_4t_pthin_nw_1 NOT INTERACT asym_rf 
bpgate_4t_pthin_nw = bpgate_4t_pthin_nw_2 NOT RFDUMMY5T  //  pmos_rf33_nw

//* Define device -- xdev pmos_rf_5t
pgate_5t_pthin = pgate_4t_pthin_2 AND RFDUMMY5T  //  pmos_rf_5t

//***** Define connectivity/via layer -- rfdmy56 ****
rfdmy56 = RFDUMMY5T OR RFDUMMY6T 

//* Define device -- xdev pmos_rf_nw_5t
pgate_5t_pthin_nw = pgate_4t_pthin_nw_2 AND RFDUMMY5T  //  pmos_rf_nw_5t

//* Define device -- xdev pmos_rf33_5t
bpgate_5t_pthin = bpgate_4t_pthin_2 AND RFDUMMY5T  //  pmos_rf33_5t

//* Define device -- xdev pmos_rf33_nw_5t
bpgate_5t_pthin_nw = bpgate_4t_pthin_nw_2 AND RFDUMMY5T  //  pmos_rf33_nw_5t

//* Define device -- xdev mimcap_wos
capm5_rf3ta1 = capm5b AND CTMDMY 
capm5_rf3ta2 = capm5_rf3ta1 NOT CTMDMYUD 
capm5_rf3ta3 = capm5_rf3ta2 AND RFDUMMY1 
capm5_rf3ta = capm5_rf3ta3 NOT RFDUMMYUD 
capm5_rf3t_shield_m4 = capm5_rf3ta INSIDE M4  //  modified by KMLiu
capm5_rf3t_woa = capm5_rf3ta NOT capm5_rf3t_shield_m4 
capm5_rf3t_shield_m3 = capm5_rf3ta INSIDE M3  //  Added by KMLiu
capm5_rf3t_wob = capm5_rf3t_woa NOT capm5_rf3t_shield_m3 
capm5_rf3t_shield_poly = capm5_rf3ta INSIDE POLY1  //  Added by KMLiu
capm5_rf3t_woc = capm5_rf3t_wob NOT capm5_rf3t_shield_poly 
capm5_rf3t_shield_ntn = capm5_rf3ta INSIDE NTN  //  Added by KMLiu
capm5_rf3t = capm5_rf3t_woc NOT capm5_rf3t_shield_ntn  //  new mimcap no shield
capm5_rf3t_1p0 = capm5_rf3t INTERACT capdmy1p0 

//* Define device -- xdev mimcap_2p0_wos
capm5_rf3t_2p0 = capm5_rf3t INTERACT capdmy2p0 

//* Define device -- xdev mimcap_shield
capm5_rf3ta_ud = capm5_rf3ta2 AND RFDUMMYUD 
capm5_rf3t_shield_m4_ud = capm5_rf3ta_ud INSIDE M4  //  modified by KMLiu
capm5_rf3t_shield_m4_1p0_ud1 = capm5_rf3t_shield_m4_ud INTERACT capdmy1p0 
capm5_rf3t_shield_m4_1p0 = capm5_rf3t_shield_m4 INTERACT capdmy1p0 
capm5_rf3t_shield_m4_1p0_ud = capm5_rf3t_shield_m4_1p0_ud1 OR capm5_rf3t_shield_m4_1p0 

//* Define device -- xdev mimcap_2p0_shield
capm5_rf3t_shield_m4_2p0_ud1 = capm5_rf3t_shield_m4_ud INTERACT capdmy2p0 
capm5_rf3t_shield_m4_2p0 = capm5_rf3t_shield_m4 INTERACT capdmy2p0 
capm5_rf3t_shield_m4_2p0_ud = capm5_rf3t_shield_m4_2p0_ud1 OR capm5_rf3t_shield_m4_2p0 

//* Define device -- xdev moscap_rf_1
varnwm_rf1 = nxwell AND VARDMY 
varnwm_rf2 = varnwm_rf1 AND RFDUMMY1 
varnwmc_rf_1 = varnwm_rf2 NOT OD2  //  modified by KMLiu
all_bc = PV_P OR PV_N  //  Original definition is (BC1 OR BC2).
varnwmc_rf_2 = varnwmc_rf_1 NOT INTERACT all_bc 
varnwmc_rf_3 = varnwmc_rf_2 NOT INTERACT VTDN 
varnwmc_rf_nw_1 = varnwmc_rf_3 NOT DNW 
varnwmc_rf_nw = varnwmc_rf_nw_1 NOT SBDUMMY  // moscap_rf_nw
varnwmc_rf_nw1 = COPY varnwmc_rf_nw 

//* Define device -- xdev moscap_rf_nw
vargt3_rf1 = vargt3 AND RFDUMMY1 
vargt3_rf = vargt3_rf1 NOT OD2  //  core mos varactor 3 terminals

//* Define device -- xdev moscap_rf33_1
varnwm_rf3 = varnwm_rf2 AND OD2 
varnwmi_rf_nw_1 = varnwm_rf3 NOT DNW 
varnwmi_rf_nw = varnwmi_rf_nw_1 NOT SBDUMMY  // moscap_rf33_nw
varnwmi_rf_nw1 = COPY varnwmi_rf_nw 

//* Define device -- xdev moscap_rf33_nw
bvargt3_rf = vargt3_rf1 AND OD2  //  io mos varactor 3 terminals

//* Define device -- xdev moscap_rf_2
varnwmc_rf_dnw_1 = varnwmc_rf_3 AND DNW 
varnwmc_rf_dnw = varnwmc_rf_dnw_1 NOT SBDUMMY  // moscap_rf

//* Define device -- xdev moscap_rf33_2
varnwmi_rf_dnw_1 = varnwm_rf3 AND DNW 
varnwmi_rf_dnw = varnwmi_rf_dnw_1 NOT SBDUMMY  // moscap_rf33

//* Define device -- xdev rppolywo_rf
prpop_rf3t = prpop3 AND RFDUMMY1  //  rppolywo_rf 3 terminals

//* Define device -- xdev rppolyhri_rf
lrpop_rf1 = hrpop4 AND RFDUMMY1 
ppoly = poly AND PIMP  //  For HRI high poly resistor terminals
lrpop_rf = lrpop_rf1 INTERACT ppoly 

//* Define device -- xdev rppolyl_rf
prpip_rf1 = prpip1 AND RPDMYX 
prpip_rf2 = prpip_rf1 NOT RPDMY1 
prpip_rf3t = prpip_rf2 AND RFDUMMY1 
rpoly = POLY1 OR DPO 
rppoly_rf_edge = prpip_rf3t INSIDE EDGE rpoly 
l_rppoly_rf = LENGTH rppoly_rf_edge  >= 2  < 99999999 
rppolyl_rf_3t = prpip_rf3t WITH EDGE l_rppoly_rf  //  rppolyl_rf 3 terminal >2

//* Define device -- xdev rppolys_rf
rppolys_rf_3t = prpip_rf3t NOT rppolyl_rf_3t  //  rppolys_rf 3 terminal <2

//* Define device -- xdev sbd_rf
schottky_n1 = mdiff AND NIMP 
schottky_n2 = schottky_n1 AND nxwell 
schottky_n = schottky_n2 AND SBDUMMY 
schottky_body1 = nxwell INTERACT schottky_n 
schottky_p1 = diff CUT PIMP 
schottky_p2 = schottky_p1 AND nxwell 
schottky_p = schottky_p2 AND SBDUMMY 
schottky_body2 = schottky_body1 INTERACT schottky_p 
schottky_body3 = schottky_body2 INTERACT SBDUMMY 
schottky_body5 = schottky_body3 AND RFDUMMY1 
sbd_rf = schottky_body5 INTERACT DNW 

//* Define device -- xdev sbd_rf_nw
sbd_rf_nw1 = schottky_body5 NOT INTERACT DNW 
sbd_rf_nw = sbd_rf_nw1 NOT OD2 

//* Define device -- xdev ndio_sbd_mac
sbd_rf_nw_od2 = sbd_rf_nw1 AND OD2 

//* Define device -- xdev ndio_hia_rf
hia_ndio1 = tndiff AND HIA_DUMMY 
hia_ndio2 = hia_ndio1 AND psub 
hia_ndio_rf = hia_ndio2 AND RFDUMMY1 
hia_ndio_rf_r = HIA_DUMMY INTERACT hia_ndio_rf 

//* Define device -- xdev pdio_hia_rf
hia_pdio1 = tpdiff AND HIA_DUMMY 
hia_pdio2 = hia_pdio1 AND nxwell 
hia_pdio_rf = hia_pdio2 AND RFDUMMY1 
hia_pdio_rf_r = HIA_DUMMY INTERACT hia_pdio_rf 

//***** Define connectivity/via layer -- RFDMY_HIA_psub ****
RFDMY_HIA_bulk1 = nxwell AND HIA_DUMMY 
RFDMY_HIA_bulk2 = RFDMY_HIA_bulk1 INSIDE RFDUMMY1 
RFDMY_HIA_bulk = RFDUMMY1 INTERACT RFDMY_HIA_bulk2 
RFDMY_HIA_psub = RFDMY_HIA_bulk NOT nxwell 

//***** Define connectivity/via layer -- rfpad_r ****
m6_pad = M6 AND RFPADDMY 
rfpad1 = RFPADDMY AND m6_pad 
m5_pad = M5 AND RFPADDMY 
rfpad2 = rfpad1 INTERACT m5_pad 
rfpad3 = rfpad2 AND rpoly 
cv5 = VIA5i AND CTM5  //  via for CTM5/M6
tv51 = VIA5i NOT cv5  //  
ind_via = VIA5i AND ind_dmy 
VIA5a = tv51 NOT ind_via  //  via for M5/M6
cv_cmma5 = VIA5i AND CMM5  //  via for CTM5/M6
cv_cmm5 = cv_cmma5 NOT cv5 
VIA5 = VIA5a NOT cv_cmm5 
rfpad = rfpad3 INTERACT VIA5 
rfpad_r = COPY rfpad 

//* Define device -- xdev lowcpad_rf
ext_rfpad = EXTENTS rfpad //  For calculate lt/wt

//* Define device -- xdev lcesd1_rf
lcesd_p_rf1 = lcesd_p AND RFDUMMY1 
lcesd_p_rf = lcesd_p_rf1 INTERACT ESD2DUMMY 
lcesd1_rl_1 = lcesd_p_rf AND lcesd1 
lcesd1_rl_2 = lcesd1_rl_1 INTERACT tpdiff 
lcesd1_rl = lcesd1_rl_2 NOT lcesd2  // lcesd1_rf 50fF

//***** Define connectivity/via layer -- lcesdp ****
lcesdp = tpdiff AND lcesd_p 

//***** Define connectivity/via layer -- lcesdm ****
lcesdm = tndiff AND lcesd_m 

//* Define device -- xdev lcesd2_rf
lcesd2_rl_1 = lcesd_p_rf AND lcesd2 
lcesd2_rl_2 = lcesd2_rl_1 INTERACT tpdiff 
lcesd2_rl = lcesd2_rl_2 NOT lcesd1  // lcesd2_rf 100fF

//* Define device -- xdev xjvar_nr36
varnwj_rf = nxwell AND JVARD 
jvar1_rf = varnwj_rf INTERACT tpdiff 
jvar2_rf = jvar1_rf INTERACT tndiff 
jvar3_rf = jvar2_rf NOT RFDUMMY 
jvar_rf3t = jvar3_rf AND RFDUMMY1  //  Junction varactor 3 terminals
jvarp_rf = jvar2_rf AND tpdiff 
jvarn_rf = jvar2_rf AND tndiff 

//***** Define connectivity/via layer -- nld40g5_reg ****
ngthv1 = gate_hv AND NIMP 
ngthv2 = ngthv1 AND HVPW 
ngthv3 = ngthv2 AND NBL 
ngthv4 = ngthv3 INTERACT HVPBi 
ngthv5 = ngthv4 INTERACT DPW 
nld_gate1 = ngthv5 INTERACT SH_P 
nld_gate2 = nld_gate1 NOT INTERACT VTDN 
nld_gate = nld_gate2 AND HV40DMY 
nld32g5_r1 = nld_gate AND HV32DMY 
nld40g5_r1 = nld_gate NOT nld32g5_r1 
nld24g5_r1 = nld_gate AND NLD24DMY 
nld40g5_r2 = nld40g5_r1 NOT nld24g5_r1 
nld18g5_r1 = nld_gate AND HV18DMY 
nld40g5_r3 = nld40g5_r2 NOT nld18g5_r1 
hvndfs_bcd46a = tndiff AND HVDMY1 
hvndfd_bcd46a = HVNW INTERACT hvndfs_bcd46a 
hvndfd_bcd46 = hvndfd_bcd46a INTERACT ngthv5 
hvndfd_nld18g5 = hvndfd_bcd46 INTERACT SH_N 
nld40g5_r4 = nld40g5_r3 NOT INTERACT hvndfd_nld18g5 
nld40g5_ac = nld40g5_r4 AND MACRODMY 
nld40g5_reg = nld40g5_r4 NOT nld40g5_ac 

//***** Define connectivity/via layer -- hvndfs ****
hvpdfs_bcd46a = tpdiff AND HVDMY1 
hvndfs_bcd46b = hvndfs_bcd46a TOUCH hvpdfs_bcd46a 
hvndfs_bcd46c = hvndfs_bcd46b AND NBL 
hvndfs_bcd46d = hvndfs_bcd46c AND HVPW 
