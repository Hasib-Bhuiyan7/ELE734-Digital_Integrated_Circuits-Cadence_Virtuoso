   property W,L,AS,AD,PS,PD
   W = perimeter_coincide(pa50g5_reg,hvpdfs)
   L = area(pa50g5_reg) / W
   AW = DFM_NUM_VAL (hvpdfd_pa50g5_reg,"NW") * UNIT_LENGTH()
   PI_S_OD = perimeter_inside(S,pthin)
   IF(PI_S_OD > 0) {
    AS = area(S) * W /PI_S_OD
