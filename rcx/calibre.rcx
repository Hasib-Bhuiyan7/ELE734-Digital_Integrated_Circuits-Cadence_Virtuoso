pnwdio_ell_od2 = pnwdio3_ell INTERACT OD2  //  ULL pnwdio_5_ell
pnwdio_ell = pnwdio3_ell NOT pnwdio_ell_od2  //  ULL pnwdio_ell

//* Define device --  nch_sf3
tngate_cis1 = gate_lv AND CIRPO 
tngate_cis2 = tngate_cis1 AND OD2 
tngate_cis31 = tngate_cis2 INTERACT NIMP 
tngate_cis3 = tngate_cis31 NOT NMOS_VT 
tngate_cis4 = tngate_cis3 INSIDE PWELLX 
tngate_cis5 = tngate_cis4 AND CELLM 
nsfgate1 = tngate_cis5 NOT CELL_RS 
nsfgate2 = nsfgate1 NOT INTERACT CELL_TX 
nsfgate = nsfgate2 NOT CELL_SL  //   3.3V Source follower nmos cell device

//* Define device --  nch_rt3
nrtgate1 = tngate_cis5 AND CELL_RS 
nrtgate = nrtgate1 NOT CELL_SL  //   3.3V Reset gate nmos cell device

//* Define device --  nch_rs3
nrsgate1 = tngate_cis5 NOT CELL_RS 
nrsgate = nrsgate1 AND CELL_SL  //   3.3V Row Select gate nmos cell device

//***** Define connectivity/via layer -- ntggate ****
tngate_cis6 = tngate_cis3 CUT PWELLX 
tngate_cis7 = tngate_cis6 INTERACT NPS 
tngate_cis8 = tngate_cis7 INTERACT PPS 
tngate_cis9 = tngate_cis8 INTERACT CELLH 
tngate_cis10 = tngate_cis9 AND CELLM 
ntggate = tngate_cis10 INTERACT CELL_TX  //   3.3V transfer gate nmos cell device

//***** Define connectivity/via layer -- pidiff ****
tdiff1 = mdiff NOT NIMP 
tdiff2 = tdiff1 NOT PIMP 
tdiff = tdiff2 NOT gate_all 
pidiff1 = tdiff AND CELLH 
pidiff = pidiff1 AND PPS 

//***** Define connectivity/via layer -- ntgdrain ****
ntgdrain = tndiff AND CELL_TX 

//* Define device -- xdev pindio_cis
pindio1 = diff CUT PWELLX 
pindio2 = pindio1 AND CELLM 
pindio3 = pindio2 AND CELLH 
pindio4 = pindio3 AND PPS 
pindio5 = pindio4 NOT POLY1 
pindio = pindio5 AND NPS 

//* Define device --  ST
cngate1 = tngate1 AND CIRPO 
PWELL = psub OR PWELLX 
cngate2 = cngate1 INTERACT PWELL 
cngate3 = cngate2 AND OD2 
cngate4 = cngate3 AND NMOS_VT 
cngate6 = cngate4 NOT CELLM 
cngate = cngate6 NOT CELLH  //    3.3V Select transistor nmos cell device

//* Define device --  RT
cnhgate = cngate6 AND CELLH  //    3.3V Rest transistor nmos cell device

//* Define device --  SF
cngate5 = cngate4 AND CELLM 
cnmgate = cngate5 NOT CELLH  //    3.3V Source follower nmos cell device

//* Define device -- diode DC
nps2 = NPS AND CIRPO 
wdio_s1 = nps2 NOT PWELLX 
wdio_s2 = wdio_s1 NOT INTERACT POLY1 
wdio_s3 = wdio_s2 NOT CI 
wdio_s = wdio_s3 NOT PPS  //    NPS_PSUB diode

//* Define device -- diode DY
pwdio_s = wdio_s3 AND PPS  //    NPSPPS_PSUB diode

//* Define device -- xdev DZ1
cwdio_s = wdio_s2 AND CI  //    CI_PSUB diode

//* Define device -- diode nwdio_bg_cis
nwdio_bg1 = diff AND OD2 
nwdio_bg2 = nwdio_bg1 AND CIRPO 
nwdio_bg3 = nwdio_bg2 AND BGP 
nwdio_bg = nwdio_bg3 AND BGN 

//***** Define connectivity/via layer -- nw_bg_diff ****
nw_bg_diff1 = tdiff AND BGN 
nw_bg_diff = nw_bg_diff1 AND BGP 

//* Define device --  HZ
hvgate_flash = gate_norf AND hvwell  //  special for flash
hngate1 = hvgate_flash AND NIMP 
hngate2 = hngate1 AND NOPW 
hzgate1 = hngate2 NOT HNVT 
hzgate2 = hzgate1 NOT NTN 
hzgate = hzgate2 NOT nfgate 

//* Define device --  HN
hngate = hngate2 AND HNVT 

//* Define device --  HP
hpgate1 = hvgate_flash AND PIMP 
hpgate2 = hpgate1 AND HVNW 
hpgate3 = hpgate2 NOT INTERACT NWELL  // separate M(HP) from MP(pch_5t) (BCD12V)
hpgate = hpgate3 NOT INTERACT PDD_BCD  // separate M(HP) from LDDP(pa14_g2) (BCD12V)

//* Define device -- xdev DZ2
zenpdif1 = pdio_b INTERACT dz_ring 
zenpdif = zenpdif1 AND HVNW  //   Zenar diode (flash) P+/HVNW

//* Define ERC or other layers
psub_float1 = psub NOT INTERACT RWDMY  //  exclude HVPW resistor for floating psub check
psub_float2 = psub_float1 NOT INTERACT BJTDMY  //  exclude psub BJT for floating psub check
psub_float = psub_float2 NOT INTERACT gate_hv  //  exclude psub of LDMOS Drain for floating psub check

//***** Define connectivity/via layer -- polyCont ****
pl2co = POLY2 AND CONT  //  define POLY2 contact
pl1co = CONT NOT pl2co  //  define OD/POLY1 contact
polyCont = pl1co AND POLY1 

//***** Define connectivity/via layer -- nemit_od2 ****
nemit_od2 = nemit_gen INTERACT OD2 

//***** Define connectivity/via layer -- mom3p1 ****
mom3p11 = metal3 AND MOMDMY23 
mom3p1 = mom3p11 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- fgtCont ****
fgtCont1 = PO1 AND CONT 
fgtCont = FGT AND fgtCont1 

//***** Define connectivity/via layer -- poly_hvnw ****
poly_hvnw = poly_term AND HVNW 

//***** Define connectivity/via layer -- mom5m1 ****
mom5p11 = metal5 AND MOMDMY23 
mom5m1 = mom5p11 NOT INTERACT MOMDMY25 

//***** Define connectivity/via layer -- nbl_nplug ****
nwell_no_dpw = nxwell NOT INTERACT DPW 
nbl_nplug1 = nwell_no_dpw AND NBL  //  commanded by pywangi 
nbl_nplug2 = HVNWi AND NBL 
nbl_nplug3 = nbl_nplug1 OR nbl_nplug2 
nbl_nplug4 = tndiff AND nbl_nplug3  //  added by pywangi
nbl_nplug5 = nbl_nplug4 NOT SH_P 
nbl_nplug6 = nbl_nplug5 INTERACT CONT 
hvnw_dpw1 = HVNW INSIDE DPW 
hvnw_dpw = hvnw_dpw1 INTERACT SH_N 
nbl_nplug = nbl_nplug6 NOT hvnw_dpw 

//***** Define connectivity/via layer -- ctm_via ****
ctm_via = COPY cv5 
c_pmall = nxwell NOT NTN  //  pmos all for WPE (clear tone)
c_pmcore = c_pmall NOT OD2  //  pmos all for WPE (clear tone)

//***** Define connectivity/via layer -- dpwc ****
dpwc = DPW AND HVPW 

//***** Define connectivity/via layer -- poly_psub ****
poly_psub = poly_term AND psub 

//***** Define connectivity/via layer -- ncoll_od2 ****
pbase_od2 = pbase_gen INTERACT OD2 
ncoll2 = ncollrg TOUCH pbase_od2 
ncoll_od2 = ncoll2 OR pbase_od2  // define 3.3/5V BJT[N1] collector

//***** Define connectivity/via layer -- n_psub ****
n_psub = BULK NOT psub2_ring 

//***** Define connectivity/via layer -- gate1_not_IO1 ****
gate1_not_IO1 = gate_lv NOT OD2 
c_pmIO = c_pmall AND OD2  //  pmos all for WPE (clear tone)

//***** Define connectivity/via layer -- mim_po ****
mim_po = POLY1 INTERACT capm5_rf3t_shield_poly 

//***** Define connectivity/via layer -- mom4m2 ****
mom4p21 = metal4 AND MOMDMY24 
mom4m2 = mom4p21 NOT INTERACT MOMDMY25 

//***** Define connectivity/via layer -- pplug ****
pplug0 = tpdiff AND psub 
PDD_in_hvnw = PDD INSIDE HVNW 
pplug_in_pdd = tpdiff AND PDD_in_hvnw 
pplug1 = pplug0 OR pplug_in_pdd 
pplug3 = pplug1 INTERACT CONT 
tndiffco = tndiff INTERACT CONT 
pplug2 = pplug1 INTERACT tndiffco 
pplug = pplug3 OR pplug2  //  define p_sub contact

//***** Define connectivity/via layer -- hia_rf_via ****
hia_rf_via1 = RFDMY_HIA_psub AND psub 
rw1 = BULK NOT ANWEL 
rw_inside_dnw = rw1 INSIDE DNW 
rw_inside_nbl = rw1 INSIDE NBL 
rw_dnw_nbl = rw_inside_dnw OR rw_inside_nbl 
rw_inside_hvnwi = rw1 INSIDE HVNWi 
rw = rw_dnw_nbl OR rw_inside_hvnwi 
hia_rf_via2 = hia_rf_via1 NOT rw 
nw_dnw1 = NWELL INTERACT DNW 
nw_dnw = nw_dnw1 INTERACT rw 
hia_rf_via = hia_rf_via2 NOT nw_dnw 

//***** Define connectivity/via layer -- crt_poly ****
crt_poly1 = POLY1 INTERACT MOMDMYall_5 
crt_poly = crt_poly1 AND MOMDMYall_5 

//***** Define connectivity/via layer -- ind_mt ****
sz_inddmy = SIZE INDDMY BY -50 
ovlp_inddmy = INDDMY NOT sz_inddmy 
mt_1ovlp_inddmy = mt5x AND ovlp_inddmy 
inddmy_std = INDDMY INTERACT mt_1ovlp_inddmy 
ind_std_dmy = ind_dmy INTERACT inddmy_std 
std_ind1 = mt6x AND ind_std_dmy 
std_ind2 = SIZE std_ind1 BY 2 
std_ind3 = SIZE std_ind2 BY -2  //  SIZE OVER_UNDER BY 2 maximum spacing 3
std_hole = HOLES std_ind3 
std_ind4 = std_ind1 INTERACT std_hole 
ind_mt1 = std_ind1 NOT std_ind4 
s_ind_dmy = SIZE ind_dmy BY -50 
ind_mt2 = ind_mt1 AND s_ind_dmy 
std_ind5 = ind_mt1 INTERACT ind_mt2 
ind_mt_a = ind_mt1 NOT std_ind5 
sym_ct_mu_x_20k_ind = INDDMY WITH TEXT "spiral_sym_ct_mu_x_20k" IND_TEXT 
ind_mt_b = ind_mt_a NOT INTERACT sym_ct_mu_x_20k_ind 
sym_ct_mu_x_40k_ind = INDDMY WITH TEXT "spiral_sym_ct_mu_x_40k" IND_TEXT 
ind_mt = ind_mt_b NOT INTERACT sym_ct_mu_x_40k_ind 

//***** Define connectivity/via layer -- rfdmy56_via ****
rfdmy56_via1 = rfdmy56 AND psub 
rfdmy56_via2 = rfdmy56_via1 NOT rw 
rfdmy56_via = rfdmy56_via2 NOT nw_dnw 

//***** Define connectivity/via layer -- mom4m1 ****
mom4p11 = metal4 AND MOMDMY23 
mom4m1 = mom4p11 NOT INTERACT MOMDMY25 
celdiffg = fggate OR tndiff 

//***** Define connectivity/via layer -- poly_nw ****
poly_nw = poly_term AND nxwell 

//***** Define connectivity/via layer -- mim_sandwich_psub_via ****
mim_sandwich_psub_via = capm3a_sandwich5 AND psub 

//***** Define connectivity/via layer -- c2poly ****
rp2 = rp1 NOT INTERACT POLY1 
p2rdum = rp2 INTERACT POLY2 
resp2 = POLY2 AND p2rdum  //  poly2 resistor layer
c2poly = POLY2 NOT resp2  //  poly2 interconnect

//***** Define connectivity/via layer -- mom5p1 ****
mom5p1 = mom5p11 INTERACT MOMDMY25 
erc_exclude1 = VARDMYX OR VARG3 
erc_exclude = erc_exclude1 OR VARG6 
erc_mos_gates = gate_norf NOT erc_exclude 
erc_nmos_gates1 = erc_mos_gates INTERACT NIMP 
erc_nmos_gates2 = erc_nmos_gates1 NOT nxwell 
erc_nmos_gates3 = erc_nmos_gates2 NOT HVNW 
erc_nmos_gates4 = erc_nmos_gates3 NOT NDD 
erc_nmos_gates = erc_nmos_gates4 NOT NDD_BCD 

//***** Define connectivity/via layer -- mim_hvpw_via ****
mim_hvpw_via = mim_term AND HVPW 

//***** Define connectivity/via layer -- tfr ****
tfr = M0 NOT MSi 
HVNW_float1 = HVNW NOT INTERACT RWDMY  //  exclude resistor for floating HVNW check
HVNW_float2 = HVNW_float1 NOT INTERACT rpbody_r 
HVNW_float3 = HVNW_float2 NOT INTERACT rpdd_hv 
HVNW_float4 = HVNW_float3 NOT INTERACT BJTDMY  //  exclude HVNW BJT for floating HVNW check
HVNW_float5 = HVNW_float4 NOT INTERACT DIODMY  //  exclude HVNW DIODE for floating HVNW check
HVNW_float = HVNW_float5 NOT INTERACT gate_hv  //  exclude HVNW of LDMOS Drain for floating HVNW check

//***** Define connectivity/via layer -- nxwell_npn ****
ncolls_all = ncollrg1 TOUCH pbase_gen 
ncollsa_all = ncolls_all TOUCH nemit_gen1 
nxwell_npn = ncolls_all NOT ncollsa_all 

//***** Define connectivity/via layer -- odCont ****
odCont1 = pl1co NOT POLY1 
odCont = odCont1 NOT fgtCont 

//***** Define connectivity/via layer -- indpin ****
indpin = mt5x AND ind_dmy 

//***** Define connectivity/via layer -- nplug ****
nplug1a = tndiff AND nxwell 
nplug1b = tndiff AND HVNW 
nplug1_1 = nplug1a OR nplug1b 
nplug1c = tndiff AND NDD 
nplug1_2 = nplug1_1 OR nplug1c 
nplug1d = tndiff AND NDD_BCD 
nplug1 = nplug1_2 OR nplug1d 
nplug3 = nplug1 INTERACT CONT 
tpdiffco = tpdiff INTERACT CONT 
nplug2 = nplug1 INTERACT tpdiffco 
nplug = nplug3 OR nplug2  //  define N_well contact
erc_pmos_gates1 = erc_mos_gates INTERACT PIMP 
erc_pmos_gates2 = erc_pmos_gates1 AND nxwell 
erc_pmos_gates3 = erc_pmos_gates1 AND HVNW 
erc_pmos_gates4 = erc_pmos_gates2 OR erc_pmos_gates3 
erc_pmos_gates = erc_pmos_gates4 NOT PDD 

//***** Define connectivity/via layer -- mim_sandwich_hvpw_via ****
mim_sandwich_hvpw_via = capm3a_sandwich5 AND HVPW 

//***** Define connectivity/via layer -- mim_hvnw_via ****
mim_hvnw_via = mim_term AND HVNW 

//***** Define connectivity/via layer -- poly_hvpw ****
poly_hvpw = poly_term AND HVPW 

//***** Define connectivity/via layer -- mom5p2 ****
mom5p21 = metal5 AND MOMDMY24 
mom5p2 = mom5p21 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- ntap ****
nwells = nxwell OR HVNW 
ntap1 = tndiff AND nwells 
ntap2 = ntap1 INTERACT CONT 
ntap3 = ntap1 INTERACT tpdiffco 
ntap = ntap2 OR ntap3 

//***** Define connectivity/via layer -- mim_sandwich_nw_via ****
mim_sandwich_nw_via = capm3a_sandwich5 AND nxwell 
nw_ntn = nxwell OR NTN 
c_nmIO = OD2 NOT nw_ntn  //  nmos IO for WPE (clear tone) 
nxwell_float1 = nxwell NOT INTERACT VARDMY  //  exclude nwell under VAR for floating nwell check
nxwell_float2 = nxwell_float1 NOT INTERACT RWDMY  //  exclude nwell resistor for floating nwell check
nxwell_float = nxwell_float2 NOT INTERACT BJTDMY  //  exclude nwell under BJTDMY for floating nwell check

//***** Define connectivity/via layer -- indm6m ****
indm6a = SIZE INDDMY BY 0.005 
indm6 = indm6a AND metal6 
indm6m = indm6 AND IND_MP 
celdifnf = nfgate OR tndiff 

//***** Define connectivity/via layer -- VIA2 ****
cv2 = VIA2i AND CTM2  //  via for CTM2/M3
VIA2 = VIA2i NOT cv2  //  via for M3/M3

//***** Define connectivity/via layer -- indm6p ****
indm6p1 = indm6 NOT IND_MP 
indm6p2 = indm6p1 NOT INTERACT IND_MP 
indm6p = indm6p2 NOT IND_D4 

//***** Define connectivity/via layer -- mom5m2 ****
mom5m2 = mom5p21 NOT INTERACT MOMDMY25 

//***** Define connectivity/via layer -- mim_sandwich_hvnw_via ****
mim_sandwich_hvnw_via = capm3a_sandwich5 AND HVNW 

//***** Define connectivity/via layer -- dnwc ****
dnwc = DNW AND nxwell 

//***** Define connectivity/via layer -- tiod ****
tioda = diff NOT tpdiff 
tiodb = tioda NOT tndiff 
tiod1 = tiodb NOT POLY1 
tiod2 = tiod1 NOT RPO 
tiod3 = tiod2 NOT RPDMYa 
tiod = tiod3 NOT RWDMYa 

//***** Define connectivity/via layer -- metal7 ****
#IFDEF Cu_RDL
   metal7 = COPY MD
#ELSE
   metal7 = COPY AP_Cu
#ENDIF

//***** Define connectivity/via layer -- mom4p2 ****
mom4p2 = mom4p21 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- cmm_via ****
cmm_via = COPY cv_cmm5 

//***** Define connectivity/via layer -- VIA3 ****
cv3 = VIA3i AND CTM3  //  via for CTM3/M4
VIA3 = VIA3i NOT cv3  //  via for M4/M4

//***** Define connectivity/via layer -- psub_under_hvnw_via ****
psub_under_hvnw_via = psub_term AND psub_under_hvnw 

//***** Define connectivity/via layer -- mom3m2 ****
mom3p21 = metal3 AND MOMDMY24 
mom3m2 = mom3p21 NOT INTERACT MOMDMY25 

//***** Define connectivity/via layer -- psub_under_dnw_via ****
psub_under_dnw_via = psub_term AND psub_under_dnw 

//***** Define connectivity/via layer -- pm_cbd ****
pm_cbd = PLMIDE AND CBD 

//***** Define connectivity/via layer -- indm4c ****
indm4 = indm6a AND M4Y 
indm4c = indm4 AND IND_D4 
poly_erc1 = OD INTERACT zd_hv_dio12  // od interact zd_dio reg layer
poly_erc = POLY1 NOT INTERACT poly_erc1 

//***** Define connectivity/via layer -- VIA4 ****
cv4 = VIA4i AND CTM4  //  via for CTM4/M5
VIA4 = VIA4i NOT cv4  //  via for M5/M5

//***** Define connectivity/via layer -- mom4p1 ****
mom4p1 = mom4p11 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- mom3p2 ****
mom3p2 = mom3p21 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- VIA6 ****
#IFDEF Cu_RDL
   VIA6 = COPY VIAD
#ELSE
   VIA6 = COPY CB
#ENDIF

//***** Define connectivity/via layer -- n_pplug ****
n_pplug1 = mdiff INTERACT CONT 
n_pplug2 = n_pplug1 AND PIMP 
n_pplug3 = n_pplug2 NOT gate_all 
n_pplug4 = n_pplug3 NOT nxwell 
n_pplug5 = n_pplug4 NOT HVNW 
n_pplug6 = n_pplug5 NOT rw 
n_pplug7 = n_pplug6 AND n_psub 
ldpw_inside_hvnwi = LDPW INSIDE HVNWi 
n_pplug8 = n_pplug7 NOT ldpw_inside_hvnwi 
pdd_bcd_inside_hvnwi = PDD_BCD INSIDE HVNWi 
n_pplug9 = n_pplug8 NOT pdd_bcd_inside_hvnwi 
hvpb_inside_hvnwi = HVPB INSIDE HVNWi 
n_pplug10 = n_pplug9 NOT hvpb_inside_hvnwi 
dpw_inside_hvnwi = DPW INSIDE HVNWi 
n_pplug = n_pplug10 NOT dpw_inside_hvnwi 

//***** Define connectivity/via layer -- psub_under_nbl_via ****
psub_under_nbl_via = psub_term AND psub_under_nbl 

//***** Define connectivity/via layer -- mom3m1 ****
mom3m1 = mom3p11 NOT INTERACT MOMDMY25 

//***** Define connectivity/via layer -- ptap ****
ptap1 = tpdiff AND psub 
ptap2 = ptap1 INTERACT CONT 
ptap3 = ptap1 INTERACT tndiffco 
ptap = ptap2 OR ptap3 

//***** Define connectivity/via layer -- mim_psub_via ****
mim_psub_via = mim_term AND psub 
d_nmcore = OD2 OR nw_ntn  //  nmos core for WPE (Dark tone)
c_nmcore = BULK NOT d_nmcore  //  nmos core for WPE (clear tone)

//***** Define connectivity/via layer -- mim_nw_via ****
mim_nw_via = mim_term AND nxwell 
