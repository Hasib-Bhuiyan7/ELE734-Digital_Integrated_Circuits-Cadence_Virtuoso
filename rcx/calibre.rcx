//

#IFDEF extract_parasitic_diodes
DEVICE D(dnwpsub) dnwdio psub_term DNW [
    PROPERTY A,PJ
    A = area(DNW)
    PJ = perimeter(DNW)
]
  #IFDEF compare_parasitic_diodes
    TRACE PROPERTY D(dnwpsub) A A DIO_Aerr
  #ENDIF
#ENDIF

DEVICE efuse poly_fuse poly(PLUS) poly(MINUS)

#IFDEF RC_DECK
DEVICE hvpwdnwhvnw_dio_hvpw_3t hvpwdio_18_reg tpdiff(PLUS) HVNW(MINUS) psub_under_dnw(SUB) [
	property AREA,PJ,DNW_AREA,DNW_PJ
	area=area(hvpwdio_18_reg)
	pj=perimeter(hvpwdio_18_reg)
	dnw_area=0
	dnw_pj=0
]
#ELSE
DEVICE hvpwdnwhvnw_dio_hvpw_3t hvpwdio_18_reg tpdiff(PLUS) HVNW(MINUS) psub_under_dnw(SUB) [
	property area
	area=area(hvpwdio_18_reg)
]
TRACE PROPERTY hvpwdnwhvnw_dio_hvpw_3t "area" "area" 0
#ENDIF
LVS DEVICE TYPE DIODE hvpwdnwhvnw_dio_hvpw_3t [POS=PLUS NEG=MINUS]
LVS REDUCE hvpwdnwhvnw_dio_hvpw_3t PARALLEL YES
[
	EFFECTIVE area
	area = sum( area )
]

sbd_w = EXT schottky_p schottky_n < 0.49 OPPOSITE REGION

//
DEVICE lcesd1_rf lcesd1_rl lcesdp(PLUS) lcesdm(MINUS)

//
DEVICE lcesd2_rf lcesd2_rl lcesdp(PLUS) lcesdm(MINUS)

DEVICE lowcpad_rf rfpad_r metal6(APAD) poly(AVSS) <ext_rfpad> [
  property lt,wt,lay
  A_PAD = area(ext_rfpad)
  P_PAD = perimeter(ext_rfpad)
  P_2_PAD = P_PAD * P_PAD
  AP4 = A_PAD * 16
  KKK = P_2_PAD-AP4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  lt = (P_PAD+SQ)/4
  wt = (P_PAD-SQ)/4
  lay = 6
]
TRACE PROPERTY lowcpad_rf lt lt MIMCAP_Lerr
TRACE PROPERTY lowcpad_rf wt wt MIMCAP_Werr
TRACE PROPERTY lowcpad_rf lay lay 0

#IFDEF RC_DECK
DEVICE lvpwdnwhvnw_dio_hvpw_3t lvpwdnwhvnw_dio_reg psub(PLUS) HVNW(MINUS) psub_under_dnw(SUB) [
	property AREA,PJ,DNW_AREA,DNW_PJ
	area=area(lvpwdnwhvnw_dio_reg)
	pj=perimeter(lvpwdnwhvnw_dio_reg)
	dnw_area=0
	dnw_pj=0
]
