fmom14_rf_reg3  = fmom14_rf_reg2 INTERACT MOMDMY100
fmom14_rf_reg4  = fmom14_rf_reg3 NOT INTERACT MOMDMY22
fmom14_rf_reg   = fmom14_rf_reg4 INTERACT NIMP
fmom14_mx_reg1  = MOMDMY22 NOT INTERACT RFDUMMY
fmom14_mx_reg2  = fmom14_mx_reg1 NOT INTERACT RFDUMMY1
fmom14_mx_reg3  = fmom14_mx_reg2 INTERACT mom14_5		    
fmom14_mx_reg4  = fmom14_mx_reg3 NOT INTERACT mom14_idt
fmom14_mx_reg5  = fmom14_mx_reg4 INTERACT MOMDMY100
fmom14_mx_reg   = fmom14_mx_reg5 INTERACT NIMP
mom14_mx_aux   = mom14_5 AND MOMDMY22


