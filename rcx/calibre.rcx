   PI_D_OD = perimeter_inside(D,pthin)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS
    PS = perimeter(S) * W /PI_S_OD
    PD = PS } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(D) * W / PI_D_OD
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(D) * W /PI_D_OD }
 #IFDEF ZERO_NRS_NRD 
   NRS = 0
   NRD = 0
 #ELSE 
   NRS = AS / W / W
   NRD = AD / W / W
 #ENDIF 
// Well proximity.
   SCH = ENCLOSURE_PERPENDICULAR(mvt_pgate_nomac,mvt_pgate_nomac_aux, S, 5.0 )  // "Horizontal" direction.
   SCV = ENCLOSURE_PARALLEL(mvt_pgate_nomac,mvt_pgate_nomac_aux, S, 5.0 )       // "Vertical" direction.
   SCA = TVF_NUM_FUN ( "calc_sca", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
   SCB = TVF_NUM_FUN ( "calc_scb", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
   SCC = TVF_NUM_FUN ( "calc_scc", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
]

