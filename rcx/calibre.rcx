DEVICE nch_hvsl_mac ngt_lhl tndiff(D) poly(G) tndiff(S) HVPW(B) <nthin> (S D) netlist model nch_hvsl_mac [
   property W,L,AS,AD,PS,PD
   W = (perimeter_coincide(ngt_lhl,tndiff) + perimeter_inside(ngt_lhl,tndiff)) / 2
   L = area(ngt_lhl) / W
   PI_S_OD = perimeter_inside(S,nthin)
   PI_D_OD = perimeter_inside(D,nthin)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD
     PD = perimeter(D) * W /PI_D_OD
     PS = PD } 
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS
     PS = perimeter(S) * W /PI_S_OD
     PD = PS } 
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD
     PS = perimeter(S) * W /PI_S_OD
     PD = perimeter(D) * W /PI_D_OD }  
]
#ELSE

#IFDEF extract_as_ad
DEVICE nch_hvsl_mac ngt_lhl tndiff(D) poly(G) tndiff(S) HVPW(B) <nthin> (S D) netlist model nch_hvsl_mac [
   property W,L,AS,AD
   W = (perimeter_coincide(ngt_lhl,tndiff) + perimeter_inside(ngt_lhl,tndiff)) / 2
   L = area(ngt_lhl) / W
   PI_S_OD = perimeter_inside(S,nthin)
   PI_D_OD = perimeter_inside(D,nthin)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD }
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS }
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD }
]

#ELSE
DEVICE nch_hvsl_mac ngt_lhl tndiff(D) poly(G) tndiff(S) HVPW(B) (S D) [
   property W,L
   W = (perimeter_coincide(ngt_lhl, tndiff) + perimeter_inside(ngt_lhl, tndiff)) / 2
   L = area(ngt_lhl) / W
]
#ENDIF

TRACE PROPERTY nch_hvsl_mac L L MOS_Lerr
TRACE PROPERTY nch_hvsl_mac W W MOS_Werr
#ENDIF
LVS DEVICE TYPE NMOS nch_hvsl_mac
//LVS REDUCE nch_hvsl_mac PARALLEL YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE nch_hvsl_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
DEVICE nch_hvsu_ndd_mac ngthvsu hvndfd(D) poly(G) hvndfd(S) HVPW(B) <nthin_hv27> (S D) netlist model nch_hvsu_ndd_mac [
   property W,L,AS,AD,PS,PD
   W = (perimeter_coincide(ngthvsu,hvndfd) + perimeter_inside(ngthvsu,hvndfd)) / 2
   L = area(ngthvsu) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD
     PD = perimeter(D) * W /PI_D_OD
     PS = PD } 
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS
     PS = perimeter(S) * W /PI_S_OD
     PD = PS } 
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD
     PS = perimeter(S) * W /PI_S_OD
     PD = perimeter(D) * W /PI_D_OD }  
]
#ELSE

#IFDEF extract_as_ad
DEVICE nch_hvsu_ndd_mac ngthvsu hvndfd(D) poly(G) hvndfd(S) HVPW(B) <nthin_hv27> (S D) netlist model nch_hvsu_ndd_mac [
   property W,L,AS,AD
   W = (perimeter_coincide(ngthvsu,hvndfd) + perimeter_inside(ngthvsu,hvndfd)) / 2
   L = area(ngthvsu) / W
   PI_S_OD = perimeter_inside(S,nthin_hv27)
   PI_D_OD = perimeter_inside(D,nthin_hv27)
   IF(PI_S_OD == 0) {
     AD = area(D) * W / PI_D_OD
     AS = AD }
   ELSE IF(PI_D_OD == 0) {
     AS = area(S) * W / PI_S_OD
     AD = AS }
   ELSE {
     AS = area(S) * W / PI_S_OD
     AD = area(D) * W / PI_D_OD }
]

#ELSE
DEVICE nch_hvsu_ndd_mac ngthvsu hvndfd(D) poly(G) hvndfd(S) HVPW(B) (S D) [
   property W,L
   W = (perimeter_coincide(ngthvsu, hvndfd) + perimeter_inside(ngthvsu, hvndfd)) / 2
   L = area(ngthvsu) / W
]
#ENDIF

TRACE PROPERTY nch_hvsu_ndd_mac L L MOS_Lerr
TRACE PROPERTY nch_hvsu_ndd_mac W W MOS_Werr
#ENDIF
LVS DEVICE TYPE NMOS nch_hvsu_ndd_mac
//LVS REDUCE nch_hvsu_ndd_mac PARALLEL YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE nch_hvsu_ndd_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
DEVICE LDDN(nch_tg3) ntggate poly(G) pidiff(S) ntgdrain(D) psub(B) <mdiff> netlist model nch_tg3 netlist element "M" [
  property W,L,AS,AD,PD,PS,NRD,NRS
   W=(perimeter_coincide(ntggate, pidiff ) + perimeter_coincide(ntggate, ntgdrain)) / 2
   L=area(ntggate) / W
   PI_S_OD = perimeter_inside(S,mdiff)
   IF(PI_S_OD > 0) {
    AS = area(S) * W /PI_S_OD
    PS = perimeter(S) * W /PI_S_OD
   } ELSE { AS=0 PS=0 }
   PI_D_OD = perimeter_inside(D,mdiff)
   IF(PI_D_OD > 0) {
    AD = area(D) * W /PI_D_OD
    PD = perimeter(D) * W /PI_D_OD
   } ELSE { AD=0 PD=0 }
 #IFDEF ZERO_NRS_NRD 
   NRS = 0
   NRD = 0
 #ELSE 
   NRS = AS / W / W
   NRD = AD / W / W
 #ENDIF 
]
#ELSE
#IFDEF extract_as_ad
DEVICE LDDN(nch_tg3) ntggate poly(G) pidiff(S) ntgdrain(D) psub(B) <mdiff> netlist model nch_tg3 [
  property W,L,AS,AD
   W=(perimeter_coincide(ntggate, pidiff ) + perimeter_coincide(ntggate, ntgdrain)) / 2
   L=area(ntggate) / W
   AS = area(S) * W /perimeter_inside(S,mdiff)
   AD = area(D) * W /perimeter_inside(D,mdiff)
]
#ELSE
DEVICE LDDN(nch_tg3) ntggate poly(G) pidiff(S) ntgdrain(D) psub(B) netlist model nch_tg3 [
   property W,L
   W=(perimeter_coincide(ntggate, pidiff ) + perimeter_coincide(ntggate, ntgdrain)) / 2 
   L=area(ntggate) / W
]
#ENDIF

TRACE PROPERTY LDDN(nch_tg3) L L MOS_Lerr
TRACE PROPERTY LDDN(nch_tg3) W W MOS_Lerr
#ENDIF

DEVICE ndio_hia_rf hia_ndio_rf_r psub(PLUS) tndiff(MINUS) <hia_ndio_rf> [
  property al,aw,fn
  fn = count(hia_ndio_rf)  
  A_DIO = area(hia_ndio_rf)/fn
  P_DIO = perimeter(hia_ndio_rf)/fn
  P_2_DIO = P_DIO * P_DIO
  AD4 = A_DIO * 16
  KKK = P_2_DIO-AD4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  al = (P_DIO+SQ)/4
  aw = (P_DIO-SQ)/4
]    

TRACE PROPERTY ndio_hia_rf aw aw DIO_Werr
TRACE PROPERTY ndio_hia_rf al al DIO_Lerr
TRACE PROPERTY ndio_hia_rf fn fn 0

DEVICE ndio_sbd_mac sbd_rf_nw_od2 schottky_p(PLUS) schottky_n(MINUS) <sbd_w> [
  property l,w,nf
  nf = count(schottky_p)
  w = perimeter_coincide(schottky_p,sbd_w)/2/nf
  l = area(schottky_p)/(w*nf)
 
]
TRACE PROPERTY ndio_sbd_mac nf nf 0
TRACE PROPERTY ndio_sbd_mac w w DIO_Werr
TRACE PROPERTY ndio_sbd_mac l l DIO_Lerr

