// User define devices 
#IFDEF GP_PROCESS
#IFDEF RC_DECK
DEVICE C(M5) capm5_1p0_udc ctm metal5 netlist model mimcap netlist element "X" [
  property W,L
  a_cap = area(capm5_1p0_udc)
  p_cap = perimeter(capm5_1p0_udc)
  p_2_cap = p_cap * p_cap
  ac4 = a_cap * 16
  kkk = p_2_cap-ac4
  if(kkk<0) {
  kkk=0
  }
  sq = sqrt(kkk)
  L = (p_cap+sq)/4
  W = (p_cap-sq)/4
]
#ELSE
DEVICE C(M5) capm5_1p0_udc ctm metal5 netlist model mimcap [MIMCAP_CA MIMCAP_CF]
  TRACE PROPERTY C(M5) C C 0
#ENDIF
#ENDIF

#IFDEF GP_PROCESS
#IFDEF RC_DECK
DEVICE C(M5) capm5_2p0_udc ctm metal5 netlist model mimcap_2p0 netlist element "X" [
  property W,L
  a_cap = area(capm5_2p0_udc)
  p_cap = perimeter(capm5_2p0_udc)
  p_2_cap = p_cap * p_cap
  ac4 = a_cap * 16
  kkk = p_2_cap-ac4
  if(kkk<0) {
  kkk=0
  }
  sq = sqrt(kkk)
  L = (p_cap+sq)/4
  W = (p_cap-sq)/4
]
#ELSE
DEVICE C(M5) capm5_2p0_udc ctm metal5 netlist model mimcap_2p0 [MIMCAP_2P0_CA MIMCAP_2P0_CF]
#ENDIF
#ENDIF

