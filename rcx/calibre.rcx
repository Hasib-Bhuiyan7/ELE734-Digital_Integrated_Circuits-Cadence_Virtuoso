//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

DEVICE nmos_rf nrgate_4t_nthin d_tndiff(D) poly_rf(G) s_tndiff(S) psub(B) <nrgate_rf4t> [
  property WR,LR,NR
  NR = count(nrgate_rf4t)
  WR = ((perimeter_coincide(nrgate_rf4t,d_tndiff) + perimeter_coincide(nrgate_rf4t,s_tndiff))/2)/NR
  LR = (area(nrgate_rf4t)/WR)/NR
]
TRACE PROPERTY nmos_rf LR LR RFMOS_Lerr
TRACE PROPERTY nmos_rf WR WR RFMOS_Werr
TRACE PROPERTY nmos_rf NR NR 0

DEVICE nmos_rf33 bnrgate_4t_nthin d_tndiff(D) poly_rf(G) s_tndiff(S) psub(B) <bnrgate_rf4t> [
  property WR,LR,NR
  NR = count(bnrgate_rf4t)
  WR = ((perimeter_coincide(bnrgate_rf4t,d_tndiff) + perimeter_coincide(bnrgate_rf4t,s_tndiff))/2)/NR
  LR = (area(bnrgate_rf4t)/WR)/NR
]
TRACE PROPERTY nmos_rf33 LR LR RFMOS_Lerr
TRACE PROPERTY nmos_rf33 WR WR RFMOS_Werr
TRACE PROPERTY nmos_rf33 NR NR 0

DEVICE nmos_rf33_6t bnrgate_6t_nthin d_tndiff(D) poly_rf(G) s_tndiff(S) rw_inside_dnw(B) DNW(NG) rfdmy56(PG) <bnrgate_rf4t> netlist model nmos_rf33_6t [
   property lr,wr,nr
   nr = count(bnrgate_rf4t)
   wr = ((perimeter_coincide(bnrgate_rf4t,s_tndiff)+ perimeter_coincide(bnrgate_rf4t,d_tndiff))/2)/nr
   lr = (area(bnrgate_rf4t)/wr)/nr
]
TRACE PROPERTY nmos_rf33_6t wr wr RFMOS_Werr 
TRACE PROPERTY nmos_rf33_6t lr lr RFMOS_Lerr
TRACE PROPERTY nmos_rf33_6t nr nr 0


DEVICE nmos_rf_6t nrgate_6t_nthin d_tndiff(D) poly_rf(G) s_tndiff(S) rw_inside_dnw(B) DNW(NG) rfdmy56(PG) <nrgate_rf4t> netlist model nmos_rf_6t [
   property lr,wr,nr
   nr = count(nrgate_rf4t)
   wr = ((perimeter_coincide(nrgate_rf4t,s_tndiff)+ perimeter_coincide(nrgate_rf4t,d_tndiff))/2)/nr
   lr = (area(nrgate_rf4t)/wr)/nr
]
TRACE PROPERTY nmos_rf_6t wr wr RFMOS_Werr 
TRACE PROPERTY nmos_rf_6t lr lr RFMOS_Lerr
TRACE PROPERTY nmos_rf_6t nr nr 0


DEVICE nmoscap nmoscap_reg poly(PLUS) tndiff(MINUS) <vargt> [
  property lr,wr,mr
  mr = count(vargt)
  lr = (perimeter_coincide(vargt,nmoscap_reg)/mr)/2
  A  = area(vargt)/mr
  wr = A/lr
]
TRACE PROPERTY nmoscap lr lr MOSCAP_Lerr
TRACE PROPERTY nmoscap wr wr MOSCAP_Werr
TRACE PROPERTY nmoscap mr mr 0

