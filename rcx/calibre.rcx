LVS DEVICE TYPE LDDPMOS pa18_g5_ac [D=D G=G S=S]
//LVS REDUCE pa18_g5_ac PARALLEL YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE pa18_g5_ac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

pa24g5_reg_w = pa24g5_reg COINCIDENT EDGE hvpdfd
hvpdfd_pa24g5_reg = DFM PROPERTY hvpdfd pa24g5_reg pa24g5_reg_w OVERLAP ABUT ALSO MULTI [ NG = COUNT(pa24g5_reg)] [NW = LENGTH(pa24g5_reg_w)]
#IFDEF RC_DECK
DEVICE LDDP(pa24_g5) pa24g5_reg hvpdfd(D) poly(G) hvpdfs(S) HVNW(B) <pthin> <hvpdfd_pa24g5_reg> netlist model pa24_g5 netlist element "M" [
   property W,L,AS,AD,PS,PD
   W = perimeter_coincide(pa24g5_reg,hvpdfs)
   L = area(pa24g5_reg) / W
   AW = DFM_NUM_VAL (hvpdfd_pa24g5_reg,"NW") * UNIT_LENGTH()
