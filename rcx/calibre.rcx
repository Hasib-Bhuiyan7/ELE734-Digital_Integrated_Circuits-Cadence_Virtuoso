//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE nch_hvisl_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
nch_hvnw_6t_reg_aux = (SIZE nch_hvnw_6t_reg BY WPED) AND c_nmcore
DEVICE nch_hvnw_6t nch_hvnw_6t_reg tndiff(D) poly(G) tndiff(S) psub(B) iso_hvnw(HVNW_ISO) psub_under_hvnw(SUB) <nthin> <OD> <nch_hvnw_6t_reg_aux> [
  property W,L,AS,AD,PD,PS,NRD,NRS,sa,sb,sca,scb,scc,HVNW_AREA,HVNW_PJ,PW_AREA,PW_PJ
   LR_EXT = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(nch_hvnw_6t_reg, tndiff) + perimeter_inside(nch_hvnw_6t_reg, tndiff)) / 2
   L = area(nch_hvnw_6t_reg) / W
   s = enclosure_vector( OD, 60 )
   sa = W/sum(s::W/(s::a + 0.5 *L)) - 0.5*L
   sb = W/sum(s::W/(s::b + 0.5 *L)) - 0.5*L
   PI_S_OD = perimeter_inside(S,nthin)
   PI_D_OD = perimeter_inside(D,nthin)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS
    PS = perimeter(S) * W /PI_S_OD
    PD = PS } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(D) * W / PI_D_OD
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(D) * W /PI_D_OD }
 #IFDEF ZERO_NRS_NRD 
   NRS = 0
   NRD = 0
 #ELSE 
   NRS = AS / W / W
   NRD = AD / W / W
 #ENDIF 
   HVNW_AREA = 0
   HVNW_PJ = 0
   PW_AREA = 0
   PW_PJ = 0
   // Well proximity.
   SCH = ENCLOSURE_PERPENDICULAR(nch_hvnw_6t_reg,nch_hvnw_6t_reg_aux, S, 5.0 )  // "Horizontal" direction.
   SCV = ENCLOSURE_PARALLEL(nch_hvnw_6t_reg,nch_hvnw_6t_reg_aux, S, 5.0 )       // "Vertical" direction.
   SCA = TVF_NUM_FUN ( "calc_sca", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
   SCB = TVF_NUM_FUN ( "calc_scb", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
   SCC = TVF_NUM_FUN ( "calc_scc", "device_function", SCH, SCV, W, L , LR_EXT, TOP_EXT, BOT_EXT, SCALE )
]

#ELSE
#IFDEF extract_as_ad
DEVICE nch_hvnw_6t nch_hvnw_6t_reg tndiff(D) poly(G) tndiff(S) psub(B) iso_hvnw(HVNW_ISO) psub_under_hvnw(SUB) <nthin> [
  property W,L,AS,AD
   W = (perimeter_coincide(nch_hvnw_6t_reg, tndiff) + perimeter_inside(nch_hvnw_6t_reg, tndiff)) / 2
   L = area(nch_hvnw_6t_reg) / W
  PI_S_OD = perimeter_inside(S,nthin)
  PI_D_OD = perimeter_inside(D,nthin)
  IF(PI_S_OD ==0) {
    AD = area(D) * W /PI_D_OD
    AS = AD
  }
  ELSE IF(PI_D_OD==0) {
    AS = area(S) * W /PI_S_OD
    AD = AS  }
  ELSE {
  AS = area(S) * W /perimeter_inside(S,nthin)
  AD = area(D) * W /perimeter_inside(D,nthin)
  }
  ]
#ELSE
DEVICE nch_hvnw_6t nch_hvnw_6t_reg tndiff(D) poly(G) tndiff(S) psub(B) iso_hvnw(HVNW_ISO) psub_under_hvnw(SUB) [
  property W,L
   W = (perimeter_coincide(nch_hvnw_6t_reg, tndiff) + perimeter_inside(nch_hvnw_6t_reg, tndiff)) / 2
   L = area(nch_hvnw_6t_reg) / W
]
#ENDIF

TRACE PROPERTY nch_hvnw_6t L L MOS_Lerr
TRACE PROPERTY nch_hvnw_6t W W MOS_Werr
#ENDIF
LVS DEVICE TYPE NMOS nch_hvnw_6t

