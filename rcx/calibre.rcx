DEVICE mimcap_1p0_sin capm5_1p0_ud ctm(TOP) metal5(BOT) netlist element "X" [
  property lt, wt
  A_CAP = area(capm5_1p0_ud)
  P_CAP = perimeter(capm5_1p0_ud)
  P_2_CAP = P_CAP * P_CAP
  AC4 = A_CAP * 16
  KKK = P_2_CAP-AC4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  lt = (P_CAP+SQ)/4
  wt = (P_CAP-SQ)/4
]
  TRACE PROPERTY mimcap_1p0_sin lt lt MIMCAP_Lerr
  TRACE PROPERTY mimcap_1p0_sin wt wt MIMCAP_Werr
