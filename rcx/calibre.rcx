//    Q = sum( W / L )	// sum of w / l
//    W = sqrt( P * Q )	// effective w
//    L = sqrt( P / Q )	// effective l
//]

//LVS REDUCE pch_hvau_pdd_mac SERIES D S YES
//[
//    EFFECTIVE W,L
//    P = sum( W * L )	// sum of w * l
//    Q = sum( L / W )	// sum of w / l
//    W = sqrt( P / Q )	// effective w
//    L = sqrt( P * Q )	// effective l
//]

#IFDEF RC_DECK
DEVICE MP(pch_hvs) pgthvs poly(G) hvpdfd(S) hvpdfd(D) HVNW(B) <pthin_hv> netlist model pch_hvs netlist element "M" [
  property W,L,AS,AD,PS,PD
  W = (perimeter_coincide(pgthvs,hvpdfd) + perimeter_inside(pgthvs,hvpdfd)) / 2
  L = area(pgthvs) / W
   PI_S_OD = perimeter_inside(S,pthin_hv)
   PI_D_OD = perimeter_inside(D,pthin_hv)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS
    PS = perimeter(S) * W /PI_S_OD
    PD = PS } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(D) * W / PI_D_OD
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(D) * W /PI_D_OD }  
]

#ELSE

#IFDEF extract_as_ad
DEVICE MP(pch_hvs) pgthvs poly(G) hvpdfd(S) hvpdfd(D) HVNW(B) <pthin_hv> netlist model pch_hvs [
  property W,L,AS,AD
  W = (perimeter_coincide(pgthvs,hvpdfd) + perimeter_inside(pgthvs,hvpdfd)) / 2
  L = area(pgthvs) / W
   PI_S_OD = perimeter_inside(S,pthin_hv)
   PI_D_OD = perimeter_inside(D,pthin_hv)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD }
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS }
   ELSE {
    AS = area(S) * W / perimeter_inside(S,pthin_hv)
    AD = area(D) * W / perimeter_inside(D,pthin_hv) }
]
#ELSE
DEVICE MP(pch_hvs) pgthvs poly(G) hvpdfd(S) hvpdfd(D) HVNW(B) [
   property W,L
   W = (perimeter_coincide(pgthvs, hvpdfd) + perimeter_inside(pgthvs, hvpdfd)) / 2
